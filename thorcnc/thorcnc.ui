       <!-- Spindle -->
       <item>
        <widget class="QGroupBox" name="spindleGroup">
         <property name="title"><string>Spindle</string></property>
         <layout class="QVBoxLayout">
          <property name="spacing"><number>8</number></property>
          <!-- Soll / Ist -->
          <item>
           <layout class="QGridLayout">
            <property name="verticalSpacing"><number>6</number></property>
            <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Soll:</string></property><property name="font"><font><pointsize>13</pointsize></font></property></widget></item>
            <item row="0" column="1">
             <widget class="QLabel" name="lbl_spindle_soll">
              <property name="text"><string>0</string></property>
              <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
              <property name="font"><font><pointsize>20</pointsize><bold>true</bold></font></property>
             </widget>
            </item>
            <item row="1" column="0"><widget class="QLabel"><property name="text"><string>Ist:</string></property><property name="font"><font><pointsize>13</pointsize></font></property></widget></item>
            <item row="1" column="1">
             <widget class="QLabel" name="lbl_spindle_ist">
              <property name="text"><string>0</string></property>
              <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
              <property name="font"><font><pointsize>20</pointsize><bold>true</bold></font></property>
             </widget>
            </item>
           </layout>
          </item>
          <!-- Auslastungs-Bar -->
          <item>
           <widget class="QProgressBar" name="spindle_load_bar">
            <property name="minimum"><number>0</number></property>
            <property name="maximum"><number>100</number></property>
            <property name="value"><number>0</number></property>
            <property name="minimumSize"><size><width>0</width><height>22</height></size></property>
            <property name="format"><string>%p% Load</string></property>
            <property name="alignment"><set>Qt::AlignCenter</set></property>
            <property name="font"><font><pointsize>11</pointsize></font></property>
           </widget>
          </item>
          <!-- CW / CCW / STOP -->
          <item>
           <layout class="QHBoxLayout">
            <item><widget class="QPushButton" name="btn_spindle_fwd"><property name="text"><string>CW</string></property><property name="minimumSize"><size><width>0</width><height>50</height></size></property><property name="font"><font><pointsize>14</pointsize><bold>true</bold></font></property></widget></item>
            <item><widget class="QPushButton" name="btn_spindle_rev"><property name="text"><string>CCW</string></property><property name="minimumSize"><size><width>0</width><height>50</height></size></property><property name="font"><font><pointsize>14</pointsize><bold>true</bold></font></property></widget></item>
            <item><widget class="QPushButton" name="btn_spindle_stop"><property name="text"><string>STOP</string></property><property name="minimumSize"><size><width>0</width><height>50</height></size></property><property name="font"><font><pointsize>14</pointsize><bold>true</bold></font></property></widget></item>
           </layout>
          </item>
         </layout>
        </widget>
       </item>

