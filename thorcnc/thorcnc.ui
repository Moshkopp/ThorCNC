                <!-- RECHTE SPALTE: Beschreibungen -->
                <item>
                 <widget class="QGroupBox" name="groupBox_ts_info">
                  <property name="title"><string>Beschreibung</string></property>
                  <layout class="QVBoxLayout">
                   <item>
                    <widget class="QLabel" name="lbl_ts_desc">
                     <property name="wordWrap"><bool>true</bool></property>
                     <property name="alignment">
                      <set>Qt::AlignmentFlag::AlignTop|Qt::AlignmentFlag::AlignLeft</set>
                     </property>
                     <property name="text">
                      <string>&lt;b&gt;Wechselposition X / Y / Z&lt;/b&gt;&lt;br&gt;Sicherheitsposition für den manuellen Werkzeugwechsel (Maschinenkoordinaten). Die Maschine fährt diese Position an bevor M6 den Wechsel ausführt.&lt;br&gt;&lt;br&gt;&lt;b&gt;Messposition X / Y / Z&lt;/b&gt;&lt;br&gt;Exakte XY-Position des Werkzeugmessers sowie Z-Höhe der Tasteroberfläche (Maschinenkoordinaten).&lt;br&gt;&lt;br&gt;&lt;b&gt;Spindle Zero&lt;/b&gt;&lt;br&gt;Messwert des Referenzwerkzeugs am Taster (G59.3). Alle weiteren Werkzeuglängen werden relativ dazu berechnet.&lt;br&gt;&lt;br&gt;&lt;b&gt;MAX Probe&lt;/b&gt;&lt;br&gt;Maximaler Messweg ab Startposition (negativ = nach unten). Sicherheitslimit verhindert Kollision.&lt;br&gt;&lt;br&gt;&lt;b&gt;Retract&lt;/b&gt;&lt;br&gt;Rückzug nach erstem Kontakt vor der Feinmessung (mm).&lt;br&gt;&lt;br&gt;&lt;b&gt;Search Vel&lt;/b&gt;&lt;br&gt;Geschwindigkeit für die schnelle Vorpositionierung zum Taster (mm/min).&lt;br&gt;&lt;br&gt;&lt;b&gt;Probe Vel&lt;/b&gt;&lt;br&gt;Langsame Antastgeschwindigkeit für die genaue Längenmessung (mm/min).&lt;br&gt;&lt;br&gt;&lt;b&gt;Before / After&lt;/b&gt;&lt;br&gt;G-Code der vor bzw. nach der Messung ausgeführt wird (z.B. Digitalausgänge schalten).</string>
                     </property>
                    </widget>
                   </item>
                   <item>
                    <spacer>
                     <property name="orientation"><enum>Qt::Orientation::Vertical</enum></property>
                     <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
                    </spacer>
                   </item>
                  </layout>
                 </widget>
                </item>
               </layout>
