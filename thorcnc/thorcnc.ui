           <item row="1" column="1"><widget class="QPushButton" name="z_minus_jogbutton_3"><property name="minimumSize"><size><width>60</width><height>50</height></size></property><property name="font"><font><pointsize>13</pointsize><bold>true</bold></font></property></widget></item>

