                 <item row="3" column="0" colspan="3"><widget class="Line" name="line1_ts"><property name="orientation"><enum>Qt::Horizontal</enum></property></widget></item>
                 <item row="4" column="0"><widget class="QLabel" name="lbl_dsb_ts_x"><property name="text"><string>Taster-Position X:</string></property></widget></item>
                 <item row="4" column="1"><widget class="QDoubleSpinBox" name="dsb_ts_x"><property name="minimum"><double>-10000.0</double></property><property name="maximum"><double>10000.0</double></property><property name="decimals"><number>3</number></property></widget></item>
                 <item row="4" column="2" rowspan="3"><widget class="QPushButton" name="btn_set_taster_pos"><property name="text"><string>Aktuelle Pos.</string></property></widget></item>
                 <item row="5" column="0"><widget class="QLabel" name="lbl_dsb_ts_y"><property name="text"><string>Taster-Position Y:</string></property></widget></item>
                 <item row="5" column="1"><widget class="QDoubleSpinBox" name="dsb_ts_y"><property name="minimum"><double>-10000.0</double></property><property name="maximum"><double>10000.0</double></property><property name="decimals"><number>3</number></property></widget></item>
                 <item row="6" column="0"><widget class="QLabel" name="lbl_dsb_ts_z"><property name="text"><string>Taster-Position Z:</string></property></widget></item>
                 <item row="6" column="1"><widget class="QDoubleSpinBox" name="dsb_ts_z"><property name="minimum"><double>-10000.0</double></property><property name="maximum"><double>10000.0</double></property><property name="decimals"><number>3</number></property></widget></item>
                 <item row="7" column="0" colspan="3"><widget class="Line" name="line2_ts"><property name="orientation"><enum>Qt::Horizontal</enum></property></widget></item>
                 <item row="8" column="0"><widget class="QLabel" name="lbl_dsb_ts_spindle_zero"><property name="text"><string>Spindel Nullpunkt (Z):</string></property></widget></item>
                 <item row="8" column="1"><widget class="QDoubleSpinBox" name="dsb_ts_spindle_zero"><property name="minimum"><double>-10000.0</double></property><property name="maximum"><double>10000.0</double></property><property name="decimals"><number>3</number></property></widget></item>
                 <item row="9" column="0"><widget class="QLabel" name="lbl_dsb_ts_max_probe"><property name="text"><string>MAX_PROBE Abstand:</string></property></widget></item>
                 <item row="9" column="1"><widget class="QDoubleSpinBox" name="dsb_ts_max_probe"><property name="minimum"><double>-10000.0</double></property><property name="maximum"><double>10000.0</double></property><property name="decimals"><number>3</number></property></widget></item>
                 <item row="10" column="0"><widget class="QLabel" name="lbl_dsb_ts_retract"><property name="text"><string>Rückzug (RETRACT):</string></property></widget></item>
                 <item row="10" column="1"><widget class="QDoubleSpinBox" name="dsb_ts_retract"><property name="minimum"><double>-10000.0</double></property><property name="maximum"><double>10000.0</double></property><property name="decimals"><number>3</number></property></widget></item>
