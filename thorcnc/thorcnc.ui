        <!-- ===================== PROBING TAB ===================== -->
        <widget class="QWidget" name="tab_probing">
         <layout class="QVBoxLayout" name="vl_probing_main">
          <property name="margin"><number>6</number></property>
          <property name="spacing"><number>6</number></property>

          <!-- MAIN CONTENT: Left (Params + Results) | Right (Title + Btns + Grid) -->
          <item>
           <layout class="QHBoxLayout" name="hl_probe_main">
            <property name="spacing"><number>8</number></property>

            <!-- ══════════════ LEFT COLUMN ══════════════ -->
            <item>
             <layout class="QVBoxLayout" name="vl_probe_left">
              <property name="spacing"><number>6</number></property>

              <!-- Parameters panel -->
              <item>
               <widget class="QFrame" name="frm_probe_params">
                <property name="frameShape"><enum>QFrame::StyledPanel</enum></property>
                <property name="maximumSize"><size><width>520</width><height>16777215</height></size></property>
                <property name="styleSheet"><string>QFrame { background-color: #2a2a2a; border: 1px solid #444; border-radius: 4px; } QLabel { color: #ccc; font-size: 9pt; } QDoubleSpinBox, QSpinBox, QComboBox { background: #333; color: white; border: 1px solid #555; border-radius: 3px; padding: 2px 4px; min-width: 55px; max-width: 78px; } QPushButton { border-radius: 3px; }</string></property>
                <layout class="QGridLayout" name="gl_probe_params">
                 <property name="margin"><number>8</number></property>
                 <property name="spacing"><number>5</number></property>

                 <!-- Title -->
                 <item row="0" column="0" colspan="4">
                  <widget class="QLabel">
                   <property name="text"><string>PROBING PARAMETERS</string></property>
                   <property name="styleSheet"><string>color: white; font-weight: bold; font-size: 10pt;</string></property>
                  </widget>
                 </item>

                 <!-- PROBE TOOL | val | STEP OFF | val -->
                 <item row="1" column="0"><widget class="QLabel"><property name="text"><string>PROBE TOOL</string></property></widget></item>
                 <item row="1" column="1"><widget class="QSpinBox" name="spb_probe_tool"><property name="minimum"><number>1</number></property><property name="maximum"><number>999</number></property><property name="value"><number>99</number></property></widget></item>
                 <item row="1" column="2"><widget class="QLabel"><property name="text"><string>STEP OFF</string></property></widget></item>
                 <item row="1" column="3"><widget class="QDoubleSpinBox" name="dsb_probe_step_off"><property name="value"><double>3.0</double></property><property name="decimals"><number>2</number></property></widget></item>

                 <!-- PROBE DIA | val | MAX XY DIST | val -->
                 <item row="2" column="0"><widget class="QLabel"><property name="text"><string>PROBE DIA</string></property></widget></item>
                 <item row="2" column="1"><widget class="QDoubleSpinBox" name="dsb_probe_dia"><property name="value"><double>2.0</double></property><property name="decimals"><number>3</number></property></widget></item>
                 <item row="2" column="2"><widget class="QLabel"><property name="text"><string>MAX XY DIST</string></property></widget></item>
                 <item row="2" column="3"><widget class="QDoubleSpinBox" name="dsb_probe_max_xy"><property name="value"><double>10.0</double></property><property name="maximum"><double>9999.0</double></property><property name="decimals"><number>2</number></property></widget></item>

                 <!-- PROBE RAPID | val | MAX Z DIST | val -->
                 <item row="3" column="0"><widget class="QLabel"><property name="text"><string>PROBE RAPID</string></property></widget></item>
                 <item row="3" column="1"><widget class="QDoubleSpinBox" name="dsb_probe_rapid"><property name="value"><double>500.0</double></property><property name="maximum"><double>9999.0</double></property><property name="decimals"><number>1</number></property></widget></item>
                 <item row="3" column="2"><widget class="QLabel"><property name="text"><string>MAX Z DIST</string></property></widget></item>
                 <item row="3" column="3"><widget class="QDoubleSpinBox" name="dsb_probe_max_z"><property name="value"><double>5.0</double></property><property name="maximum"><double>9999.0</double></property><property name="decimals"><number>2</number></property></widget></item>

                 <!-- PROBE SEARCH | val | XY CLEARANCE | val -->
                 <item row="4" column="0"><widget class="QLabel"><property name="text"><string>PROBE SEARCH</string></property></widget></item>
                 <item row="4" column="1"><widget class="QDoubleSpinBox" name="dsb_probe_search"><property name="value"><double>100.0</double></property><property name="maximum"><double>9999.0</double></property><property name="decimals"><number>1</number></property></widget></item>
                 <item row="4" column="2"><widget class="QLabel"><property name="text"><string>XY CLEARANCE</string></property></widget></item>
                 <item row="4" column="3"><widget class="QDoubleSpinBox" name="dsb_probe_xy_clearance"><property name="value"><double>5.0</double></property><property name="decimals"><number>2</number></property></widget></item>

                 <!-- PROBE FEED | val | Z CLEARANCE | val -->
                 <item row="5" column="0"><widget class="QLabel"><property name="text"><string>PROBE FEED</string></property></widget></item>
                 <item row="5" column="1"><widget class="QDoubleSpinBox" name="dsb_probe_feed"><property name="value"><double>50.0</double></property><property name="maximum"><double>9999.0</double></property><property name="decimals"><number>1</number></property></widget></item>
                 <item row="5" column="2"><widget class="QLabel"><property name="text"><string>Z CLEARANCE</string></property></widget></item>
                 <item row="5" column="3"><widget class="QDoubleSpinBox" name="dsb_probe_z_clearance"><property name="value"><double>2.0</double></property><property name="decimals"><number>2</number></property></widget></item>

                 <!-- EXTRA DEPTH | val | EDGE WIDTH | val -->
                 <item row="6" column="0"><widget class="QLabel"><property name="text"><string>EXTRA DEPTH</string></property></widget></item>
                 <item row="6" column="1"><widget class="QDoubleSpinBox" name="dsb_probe_extra_depth"><property name="value"><double>4.0</double></property><property name="decimals"><number>2</number></property></widget></item>
                 <item row="6" column="2"><widget class="QLabel"><property name="text"><string>EDGE WIDTH</string></property></widget></item>
                 <item row="6" column="3"><widget class="QDoubleSpinBox" name="dsb_probe_edge_width"><property name="value"><double>2.0</double></property><property name="decimals"><number>2</number></property></widget></item>

                 <!-- MOTION TYPE | combo | PROBE | toggle -->
                 <item row="7" column="0"><widget class="QLabel"><property name="text"><string>MOTION TYPE</string></property></widget></item>
                 <item row="7" column="1">
                  <widget class="QComboBox" name="combo_probe_motion">
                   <item><property name="text"><string>G38.2</string></property></item>
                   <item><property name="text"><string>G38.3</string></property></item>
                  </widget>
                 </item>
                 <item row="7" column="2"><widget class="QLabel"><property name="text"><string>PROBE</string></property></widget></item>
                 <item row="7" column="3">
                  <widget class="QPushButton" name="btn_probe_active">
                   <property name="text"><string>OFF</string></property>
                   <property name="checkable"><bool>true</bool></property>
                   <property name="styleSheet"><string>QPushButton { background: #555; color: #aaa; font-weight: bold; border-radius: 10px; border: 1px solid #666; padding: 3px; } QPushButton:checked { background: #27ae60; color: white; border-color: #2ecc71; }</string></property>
                  </widget>
                 </item>

                </layout>
               </widget>
              </item>

              <!-- Results panel -->
              <item>
               <widget class="QFrame" name="frm_probe_results">
                <property name="frameShape"><enum>QFrame::StyledPanel</enum></property>
                <property name="maximumSize"><size><width>520</width><height>16777215</height></size></property>
                <property name="styleSheet"><string>QFrame { background-color: #2a2a2a; border: 1px solid #444; border-radius: 4px; } QLabel { color: #aaa; font-size: 9pt; } QLineEdit { background: #1a1a1a; color: #00ff88; border: 1px solid #555; border-radius: 2px; font-weight: bold; font-size: 10pt; padding: 2px; min-width: 55px; } QPushButton { border-radius: 3px; font-weight: bold; }</string></property>
                <layout class="QGridLayout" name="gl_probe_results">
                 <property name="margin"><number>6</number></property>
                 <property name="spacing"><number>5</number></property>

                 <!-- X row -->
                 <item row="0" column="0"><widget class="QPushButton" name="btn_probe_clear_x"><property name="text"><string>CLEAR X</string></property><property name="styleSheet"><string>background: #3a1a1a; color: #ff6666; border: 1px solid #cc3333; border-radius: 3px; font-weight: bold;</string></property></widget></item>
                 <item row="0" column="1"><widget class="QLabel"><property name="text"><string>X-</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="0" column="2"><widget class="QLineEdit" name="le_probe_x_minus"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
                 <item row="0" column="3"><widget class="QLabel"><property name="text"><string>X CTR</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="0" column="4"><widget class="QLineEdit" name="le_probe_x_ctr"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
                 <item row="0" column="5"><widget class="QLabel"><property name="text"><string>X+</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="0" column="6"><widget class="QLineEdit" name="le_probe_x_plus"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
                 <item row="0" column="7"><widget class="QLabel"><property name="text"><string>X W</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="0" column="8"><widget class="QLineEdit" name="le_probe_x_width"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>

                 <!-- Y row -->
                 <item row="1" column="0"><widget class="QPushButton" name="btn_probe_clear_y"><property name="text"><string>CLEAR Y</string></property><property name="styleSheet"><string>background: #3a1a1a; color: #ff6666; border: 1px solid #cc3333; border-radius: 3px; font-weight: bold;</string></property></widget></item>
                 <item row="1" column="1"><widget class="QLabel"><property name="text"><string>Y-</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="1" column="2"><widget class="QLineEdit" name="le_probe_y_minus"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
                 <item row="1" column="3"><widget class="QLabel"><property name="text"><string>Y CTR</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="1" column="4"><widget class="QLineEdit" name="le_probe_y_ctr"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
                 <item row="1" column="5"><widget class="QLabel"><property name="text"><string>Y+</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="1" column="6"><widget class="QLineEdit" name="le_probe_y_plus"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
                 <item row="1" column="7"><widget class="QLabel"><property name="text"><string>Y W</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="1" column="8"><widget class="QLineEdit" name="le_probe_y_width"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>

                 <!-- Z/misc row -->
                 <item row="2" column="0"><widget class="QPushButton" name="btn_probe_clear_all"><property name="text"><string>CLEAR ALL</string></property><property name="styleSheet"><string>background: #3a1a1a; color: #ff6666; border: 1px solid #cc3333; border-radius: 3px; font-weight: bold;</string></property></widget></item>
                 <item row="2" column="1"><widget class="QLabel"><property name="text"><string>Z</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="2" column="2"><widget class="QLineEdit" name="le_probe_z"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
                 <item row="2" column="3"><widget class="QLabel"><property name="text"><string>DIAM</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="2" column="4"><widget class="QLineEdit" name="le_probe_diam"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
                 <item row="2" column="5"><widget class="QLabel"><property name="text"><string>DELTA</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="2" column="6"><widget class="QLineEdit" name="le_probe_delta"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
                 <item row="2" column="7"><widget class="QLabel"><property name="text"><string>ANGLE</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
                 <item row="2" column="8"><widget class="QLineEdit" name="le_probe_angle"><property name="text"><string>0</string></property><property name="readOnly"><bool>true</bool></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>

                </layout>
               </widget>
              </item>

             </layout>
            </item>

            <!-- ══════════════ RIGHT COLUMN ══════════════ -->
            <item>
             <layout class="QVBoxLayout" name="vl_probe_right">
              <property name="spacing"><number>6</number></property>

              <!-- Title + action buttons -->
              <item>
               <layout class="QHBoxLayout">
                <property name="spacing"><number>6</number></property>
                <item>
                 <widget class="QLabel" name="lbl_probe_section_title">
                  <property name="text"><string>OUTSIDE MEASUREMENTS</string></property>
                  <property name="styleSheet"><string>color: #aaa; font-weight: bold; font-size: 12pt;</string></property>
                 </widget>
                </item>
                <item><spacer><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer></item>
                <item>
                 <widget class="QToolButton" name="btn_probe_mode">
                  <property name="text"><string>OUTSIDE CORNERS</string></property>
                  <property name="minimumSize"><size><width>150</width><height>36</height></size></property>
                  <property name="toolButtonStyle"><enum>Qt::ToolButtonTextOnly</enum></property>
                  <property name="popupMode"><enum>QToolButton::MenuButtonPopup</enum></property>
                  <property name="styleSheet"><string>QToolButton { background-color: #444; color: white; font-weight: bold; border-radius: 4px; padding: 4px 8px; border: 1px solid #666; } QToolButton::menu-button { border-left: 1px solid #666; width: 16px; }</string></property>
                 </widget>
                </item>
                <item>
                 <widget class="QPushButton" name="btn_probe_auto_zero">
                  <property name="text"><string>AUTO ZERO</string></property>
                  <property name="minimumSize"><size><width>110</width><height>36</height></size></property>
                  <property name="styleSheet"><string>background-color: #c0392b; color: white; font-weight: bold; border-radius: 4px;</string></property>
                 </widget>
                </item>
                <item>
                 <widget class="QPushButton" name="btn_probe_help">
                  <property name="text"><string>PROBE HELP</string></property>
                  <property name="minimumSize"><size><width>110</width><height>36</height></size></property>
                  <property name="styleSheet"><string>background-color: #1e5a8a; color: white; font-weight: bold; border-radius: 4px;</string></property>
                 </widget>
                </item>
               </layout>
              </item>

              <!-- 3x3 Grid + Pre/Post Panel nebeneinander -->
              <item>
               <layout class="QHBoxLayout" name="hl_probe_grid_row">
                <property name="spacing"><number>8</number></property>

                <!-- 3x3 Probe Position Grid -->
                <item>
                 <widget class="QFrame" name="frm_probe_grid">
                  <property name="frameShape"><enum>QFrame::NoFrame</enum></property>
                  <property name="maximumSize"><size><width>432</width><height>432</height></size></property>
                  <property name="styleSheet"><string>QFrame#frm_probe_grid { background-color: #2a2a2a; border: 1px solid #555; border-radius: 25px; } QPushButton { background: #3a3a3a; border: 2px solid #555; border-radius: 8px; } QPushButton:hover { border-color: #888; background: #444; } QPushButton:checked { border-color: #00cc44; border-width: 3px; background: #2a3a2a; }</string></property>
                  <layout class="QGridLayout" name="gl_probe_grid">
                   <property name="margin"><number>18</number></property>
                   <property name="spacing"><number>3</number></property>

                   <item row="0" column="0"><widget class="QPushButton" name="btn_probe_corner_tl"><property name="minimumSize"><size><width>130</width><height>130</height></size></property><property name="maximumSize"><size><width>130</width><height>130</height></size></property><property name="checkable"><bool>true</bool></property></widget></item>
                   <item row="0" column="1"><widget class="QPushButton" name="btn_probe_edge_top"><property name="minimumSize"><size><width>130</width><height>130</height></size></property><property name="maximumSize"><size><width>130</width><height>130</height></size></property><property name="checkable"><bool>true</bool></property></widget></item>
                   <item row="0" column="2"><widget class="QPushButton" name="btn_probe_corner_tr"><property name="minimumSize"><size><width>130</width><height>130</height></size></property><property name="maximumSize"><size><width>130</width><height>130</height></size></property><property name="checkable"><bool>true</bool></property></widget></item>

                   <item row="1" column="0"><widget class="QPushButton" name="btn_probe_edge_left"><property name="minimumSize"><size><width>130</width><height>130</height></size></property><property name="maximumSize"><size><width>130</width><height>130</height></size></property><property name="checkable"><bool>true</bool></property></widget></item>
                   <item row="1" column="1"><widget class="QPushButton" name="btn_probe_center"><property name="minimumSize"><size><width>130</width><height>130</height></size></property><property name="maximumSize"><size><width>130</width><height>130</height></size></property><property name="checkable"><bool>true</bool></property></widget></item>
                   <item row="1" column="2"><widget class="QPushButton" name="btn_probe_edge_right"><property name="minimumSize"><size><width>130</width><height>130</height></size></property><property name="maximumSize"><size><width>130</width><height>130</height></size></property><property name="checkable"><bool>true</bool></property></widget></item>

                   <item row="2" column="0"><widget class="QPushButton" name="btn_probe_corner_bl"><property name="minimumSize"><size><width>130</width><height>130</height></size></property><property name="maximumSize"><size><width>130</width><height>130</height></size></property><property name="checkable"><bool>true</bool></property></widget></item>
                   <item row="2" column="1"><widget class="QPushButton" name="btn_probe_edge_bottom"><property name="minimumSize"><size><width>130</width><height>130</height></size></property><property name="maximumSize"><size><width>130</width><height>130</height></size></property><property name="checkable"><bool>true</bool></property></widget></item>
                   <item row="2" column="2"><widget class="QPushButton" name="btn_probe_corner_br"><property name="minimumSize"><size><width>130</width><height>130</height></size></property><property name="maximumSize"><size><width>130</width><height>130</height></size></property><property name="checkable"><bool>true</bool></property></widget></item>

                  </layout>
                 </widget>
                </item>

                <!-- Pre/Post Probing Panel -->
                <item>
                 <widget class="QFrame" name="frm_probe_pre_post">
                  <property name="frameShape"><enum>QFrame::NoFrame</enum></property>
                  <property name="maximumSize"><size><width>220</width><height>432</height></size></property>
                  <property name="styleSheet"><string>QFrame#frm_probe_pre_post { background-color: #2a2a2a; border: 1px solid #555; border-radius: 25px; } QLabel { color: #aaa; font-size: 9pt; font-weight: bold; } QTextEdit { background: #1a1a1a; color: #cccccc; border: 1px solid #555; border-radius: 6px; font-family: monospace; font-size: 10pt; }</string></property>
                  <layout class="QVBoxLayout" name="vl_probe_pre_post">
                   <property name="margin"><number>16</number></property>
                   <property name="spacing"><number>10</number></property>

                   <!-- BEFORE PROBING -->
                   <item>
                    <widget class="QLabel">
                     <property name="text"><string>BEFORE PROBING</string></property>
                     <property name="styleSheet"><string>color: #f39c12; font-weight: bold; font-size: 9pt; letter-spacing: 1px;</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QTextEdit" name="te_probe_before">
                     <property name="placeholderText"><string>z.B. M64 P2</string></property>
                     <property name="minimumSize"><size><width>0</width><height>80</height></size></property>
                    </widget>
                   </item>

                   <!-- AFTER PROBING -->
                   <item>
                    <widget class="QLabel">
                     <property name="text"><string>AFTER PROBING</string></property>
                     <property name="styleSheet"><string>color: #2ecc71; font-weight: bold; font-size: 9pt; letter-spacing: 1px;</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QTextEdit" name="te_probe_after">
                     <property name="placeholderText"><string>z.B. M65 P2</string></property>
                     <property name="minimumSize"><size><width>0</width><height>80</height></size></property>
                    </widget>
                   </item>

                   <item>
                    <spacer><property name="orientation"><enum>Qt::Vertical</enum></property></spacer>
                   </item>

                  </layout>
                 </widget>
                </item>

                <!-- Spacer pushes grid+panel to left -->
                <item>
                 <spacer><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer>
                </item>

               </layout>
              </item>

              <!-- Spacer pushes content to top -->
              <item>
               <spacer><property name="orientation"><enum>Qt::Vertical</enum></property></spacer>
              </item>

             </layout>
            </item>

           </layout>
          </item>

          <!-- BOTTOM BAR: Current Tool | DRO | Overrides (mirrored from main) -->
          <item>
           <widget class="QFrame" name="frm_probe_statusbar">
            <property name="frameShape"><enum>QFrame::StyledPanel</enum></property>
            <property name="minimumSize"><size><width>0</width><height>200</height></size></property>
            <property name="maximumSize"><size><width>16777215</width><height>240</height></size></property>
            <layout class="QHBoxLayout" name="hl_probe_statusbar">
             <property name="spacing"><number>12</number></property>

             <!-- Current Tool (read-only mirror) -->
             <item>
              <widget class="QGroupBox" name="probe_toolGroup">
               <property name="title"><string>Current Tool</string></property>
               <property name="minimumSize"><size><width>180</width><height>0</height></size></property>
               <property name="maximumSize"><size><width>260</width><height>16777215</height></size></property>
               <layout class="QVBoxLayout">
                <property name="spacing"><number>4</number></property>
                <property name="leftMargin"><number>6</number></property>
                <property name="topMargin"><number>14</number></property>
                <property name="rightMargin"><number>6</number></property>
                <property name="bottomMargin"><number>6</number></property>
                <!-- Tool Nr (read-only display) -->
                <item>
                 <widget class="QLabel" name="probe_tool_nr_label">
                  <property name="text"><string>T0</string></property>
                  <property name="alignment"><set>Qt::AlignCenter</set></property>
                  <property name="styleSheet"><string>background-color:#1a1a1a; color:#ffffff; font-size:22px; font-weight:bold; border:1px solid #444; border-radius:3px; padding:2px 8px;</string></property>
                 </widget>
                </item>
                <!-- Dia -->
                <item>
                 <layout class="QHBoxLayout"><property name="spacing"><number>6</number></property>
                  <item><widget class="QLabel"><property name="text"><string>&#216;</string></property><property name="styleSheet"><string>color:#888; font-size:13px;</string></property></widget></item>
                  <item><widget class="QLabel" name="probe_tool_dia_label"><property name="text"><string>0.00</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property><property name="styleSheet"><string>background-color:#1a1a1a; color:#cccccc; border:1px solid #444; border-radius:3px; font-size:16px; font-weight:bold; padding:2px 8px;</string></property></widget></item>
                 </layout>
                </item>
                <!-- Len -->
                <item>
                 <layout class="QHBoxLayout"><property name="spacing"><number>6</number></property>
                  <item><widget class="QLabel"><property name="text"><string>L</string></property><property name="styleSheet"><string>color:#888; font-size:13px;</string></property></widget></item>
                  <item><widget class="QLabel" name="probe_tool_len_label"><property name="text"><string>0.00</string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property><property name="styleSheet"><string>background-color:#1a1a1a; color:#cccccc; border:1px solid #444; border-radius:3px; font-size:16px; font-weight:bold; padding:2px 8px;</string></property></widget></item>
                 </layout>
                </item>
                <!-- Comment -->
                <item>
                 <widget class="QLabel" name="probe_tool_comment_label">
                  <property name="text"><string>-</string></property>
                  <property name="wordWrap"><bool>true</bool></property>
                  <property name="styleSheet"><string>color:#aaa; font-size:14px; padding:2px 4px;</string></property>
                 </widget>
                </item>
               </layout>
              </widget>
             </item>

             <!-- DRO (dynamisch befüllt via _setup_probe_dro) -->
             <item>
              <widget class="QGroupBox" name="probe_droFrame">
               <property name="title"><string>Position (DRO)</string></property>
               <layout class="QVBoxLayout">
                <property name="margin"><number>0</number></property>
                <item><layout class="QHBoxLayout" name="probe_dro_display_layout"/></item>
               </layout>
              </widget>
             </item>

             <!-- Overrides -->
             <item>
              <widget class="QGroupBox" name="probe_overrideBox">
               <property name="title"><string>Overrides</string></property>
               <layout class="QVBoxLayout">
