                <item><widget class="QPushButton" name="btn_jog_1_0"><property name="text"><string>1.0</string></property><property name="checkable"><bool>true</bool></property><property name="minimumSize"><size><width>0</width><height>45</height></size></property><property name="font"><font><pointsize>11</pointsize><bold>true</bold></font></property></widget></item>
