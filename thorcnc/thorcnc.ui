              <item><widget class="QSlider" name="jog_vel_slider"><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="minimum"><number>1</number></property><property name="maximum"><number>200</number></property><property name="value"><number>100</number></property><property name="minimumSize"><size><width>0</width><height>30</height></size></property></widget></item>
