           <item row="3" column="2"><widget class="QPushButton" name="x_plus_jogbutton_3"><property name="minimumSize"><size><width>60</width><height>50</height></size></property><property name="font"><font><pointsize>13</pointsize><bold>true</bold></font></property></widget></item>

           <!-- Jog Slider und Increments darunter -->
           <item row="5" column="0" colspan="3">
            <widget class="QGroupBox" name="jogBox">
             <property name="title"><string>Jog Speed &amp; Increment</string></property>
             <layout class="QVBoxLayout">
              <property name="spacing"><number>10</number></property>
              <item><widget class="QLabel" name="jog_vel_label"><property name="text"><string>Velocity: 100%</string></property><property name="font"><font><pointsize>11</pointsize></font></property></widget></item>
              <item><widget class="QSlider" name="jog_vel_slider"><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="minimum"><number>1</number></property><property name="maximum"><number>200</number></property><property name="value"><number>100</number></property><property name="minimumSize"><size><width>0</width><height>30</height></size></property></widget></item>
              <item>
               <layout class="QHBoxLayout">
                <item><widget class="QPushButton" name="btn_jog_cont"><property name="text"><string>CONT</string></property><property name="checkable"><bool>true</bool></property><property name="checked"><bool>true</bool></property><property name="minimumSize"><size><width>0</width><height>45</height></size></property><property name="font"><font><pointsize>11</pointsize><bold>true</bold></font></property></widget></item>
                <item><widget class="QPushButton" name="btn_jog_1_0"><property name="text"><string>1.0</string></property><property name="checkable"><bool>true</bool></property><property name="minimumSize"><size><width>0</width><height>45</height></size></property><property name="font"><font><pointsize>11</pointsize><bold>true</bold></font></property></widget></item>
                <item><widget class="QPushButton" name="btn_jog_0_1"><property name="text"><string>0.1</string></property><property name="checkable"><bool>true</bool></property><property name="minimumSize"><size><width>0</width><height>45</height></size></property><property name="font"><font><pointsize>11</pointsize><bold>true</bold></font></property></widget></item>
                <item><widget class="QPushButton" name="btn_jog_0_01"><property name="text"><string>0.01</string></property><property name="checkable"><bool>true</bool></property><property name="minimumSize"><size><width>0</width><height>45</height></size></property><property name="font"><font><pointsize>11</pointsize><bold>true</bold></font></property></widget></item>
               </layout>
