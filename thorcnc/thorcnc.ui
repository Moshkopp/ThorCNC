  <property name="styleSheet">
   <string>
    QTabWidget::pane { border: 1px solid #444; }
    QTabBar::tab { height: 0px; width: 0px; margin: 0px; padding: 0px; border: none; }
    QGroupBox { font-weight: bold; }
    QTabWidget#settings_tabs::pane { border: 1px solid #555; }
    QTabWidget#settings_tabs > QTabBar::tab {
        height: 32px; width: 120px; margin: 0px 2px 0px 0px;
        padding: 4px 12px; border: 1px solid #555;
        border-bottom: none; border-radius: 4px 4px 0 0;
        background: #2a2a2a; color: #aaa; font-weight: bold;
    }
    QTabWidget#settings_tabs > QTabBar::tab:selected {
        background: #1e5a8a; color: white;
    }
    QTabWidget#settings_tabs > QTabBar::tab:hover:!selected {
        background: #3a3a3a;
    }
   </string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QHBoxLayout" name="mainLayout">
    
