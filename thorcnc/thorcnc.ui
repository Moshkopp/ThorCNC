                  <item><widget class="QLineEdit" name="mdi_m6_entry"><property name="placeholderText"><string>T... M6</string></property></widget></item>
                  <item><widget class="QPushButton" name="btn_m6_change"><property name="text"><string>Load Tool</string></property></widget></item>
