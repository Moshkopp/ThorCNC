                  <item row="3" column="0"><widget class="QLabel"><property name="text"><string>Desc:</string></property><property name="font"><font><pointsize>11</pointsize></font></property></widget></item>
                  <item row="3" column="1"><widget class="QLabel" name="tool_comment_label"><property name="text"><string>-</string></property><property name="font"><font><pointsize>11</pointsize></font></property><property name="wordWrap"><bool>true</bool></property></widget></item>
