/* ThorCNC Dark Theme - Unified Line */

/* Hide main tab bar – navigation is done via nav_ buttons */
QTabWidget#tabWidget > QTabBar::tab {
    height: 0px; width: 0px; margin: 0px; padding: 0px; border: none;
}

QGroupBox { font-weight: bold; }

* {
    font-family: "Noto Sans", "Inter", "Roboto", "DejaVu Sans", "Liberation Sans", sans-serif;
    font-size: 10pt;
    color: #d0d0d0;
}

QWidget {
    background-color: #1e1e1e; /* Level 0: Main Background */
}

QMainWindow, QDialog {
    background-color: #1e1e1e;
}

/* ── Frames & Containers ── */
QFrame[frameShape="4"],  /* StyledPanel */
QFrame[frameShape="6"],
QGroupBox {
    background-color: #2a2a2a; /* Level 1: Panel Background */
    border: 1px solid #444444;
    border-radius: 4px;
}

QFrame[frameShape="4"]#frame_topbar {
    background-color: #1a1a1a;
    border: none;
    border-bottom: 1px solid #444444;
    border-radius: 0;
}

QFrame#frame_statusbar {
    background-color: #1a1a1a;
    border: none;
    border-top: 1px solid #444444;
    border-radius: 0;
}

QGroupBox {
    margin-top: 16px;
    padding-top: 8px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 4px;
    color: #cccccc;
    font-size: 9pt;
}

/* ── Frames and Groups ── */
QFrame {
    border: none; /* Let internal widgets handle their own borders unless stated otherwise */
}
QGroupBox {
    border: 1px solid #444444;
    border-radius: 4px;
    margin-top: 1ex; /* leave space at the top for the title */
    background-color: #2a2a2a;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 4px;
    color: #cccccc;
}

/* ── Standard Buttons ── */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #3d3d3d, stop:1 #2a2a2a);
    border: 1px solid #4a4a4a;
    border-radius: 6px;
    padding: 2px 10px;
    min-height: 28px;
    color: #e0e0e0;
    font-weight: bold;
}


QPushButton:hover {
    background-color: #4a4a4a;
    border-color: #666666;
}

QPushButton:pressed {
    background-color: #2a2a2a;
}

QPushButton:disabled {
    background-color: #252525;
    color: #666666;
    border-color: #333333;
}

QPushButton:checked {
    background-color: #3a7abf; /* Accent */
    border-color: #5599dd;
    color: #ffffff;
}

/* ── Utility Classes (for Entknöselung) ── */
.btn-blue {
    background-color: #3464a4;
    color: white;
    font-family: 'Bebas Kai', 'Noto Sans', sans-serif;
    font-size: 10pt;
    font-weight: bold;
    border: 1px solid #204a87;
}
.btn-blue:hover { background-color: #4682c8; }
.btn-blue:pressed { background-color: #204a87; }

.btn-green {
    background-color: #4e9a06;
    color: white;
    font-family: 'Bebas Kai', 'Noto Sans', sans-serif;
    font-size: 10pt;
    font-weight: bold;
    border: 1px solid #3b7405;
}
.btn-green:hover { background-color: #64b408; }
.btn-green[homed="true"] { background-color: #4e9a06; border-color: #a4ef0a; }

.btn-red {
    background-color: #c0392b;
    color: white;
    font-family: 'Bebas Kai', 'Noto Sans', sans-serif;
    font-size: 10pt;
    font-weight: bold;
    border: 1px solid #8e2a20;
}
.btn-red:hover { background-color: #e74c3c; }
.btn-red:disabled { background-color: #3d3d3d; color: #666; border-color: #222; }

/* ── DRO Specific Classes ── */
.dro-header {
    font-weight: bold;
    color: #aaaaaa;
    font-size: 9pt;
}

.dro-axis-label {
    font-weight: bold;
    font-size: 16pt;
    color: #ffffff;
}

.dro-value {
    background-color: #1a1a1a;
    border: 1px solid #444444;
    border-radius: 4px;
    padding: 2px 8px;
    font-family: 'Bebas Kai', 'Noto Sans', sans-serif;
    font-size: 16pt;
    color: #2ecc71; /* Work position green */
}

.dro-value[homed="false"] {
    color: #e74c3c; /* Red if not homed */
}

.dro-machine {
    color: #999999;
    font-size: 16pt;
}

.dro-dtg {
    color: #f39c12; /* Orange for distance-to-go */
    font-size: 16pt;
}

/* ── Run Controls ── */
QPushButton#btn_run,
QPushButton#btn_pause_mdi,
QPushButton#stop_button {
    min-height: 65px; /* Matched to Power/Estop buttons for symmetry */
    font-size: 14pt;
    border-radius: 6px;
    border: 1px solid #4a4a4a;
    margin: 2px 0px; /* Removed horizontal margin, handled by container */
}

QPushButton#btn_run[status="running"] {
    background-color: #27ae60;
    color: white;
}
QPushButton#btn_run[status="ready"] {
    border: 2px solid #27ae60;
    color: #2ecc71;
}

QPushButton#btn_pause_mdi[status="paused"] {
    background-color: #f39c12;
    color: white;
}
QPushButton#btn_pause_mdi[status="running"] {
    border: 2px solid #f39c12;
    color: #f39c12;
}

QPushButton#stop_button[status="active"] {
    background-color: #c0392b;
    color: white;
}

QPushButton#btn_opt {
    border: 1px solid #3a7abf;
    color: #3a7abf;
    min-height: 38px;
    font-size: 14pt;
    font-weight: bold;
    background-color: #1a1a1a;
    border-radius: 4px;
    margin: 4px 8px; /* Standard sidebar button margin */
}

QPushButton#btn_opt:hover {
    background-color: #3a7abf;
    color: white;
}

#nav_quit {
    border: 1px solid #c0392b;
    color: #c0392b;
    font-weight: bold;
    font-size: 11pt;
    padding: 10px;
}
#nav_quit:hover {
    background-color: #c0392b;
    color: white;
}

#combo_machine_mode {
    background-color: #2a2a2a;
    border: 1px solid #444444;
    border-radius: 4px;
    padding: 4px 8px;
    min-width: 140px;
    font-weight: bold;
    font-size: 10pt;
    color: #2ecc71; /* Accent Color for Mode */
}
#combo_machine_mode:hover {
    border-color: #555555;
    background-color: #333333;
}
#combo_machine_mode QAbstractItemView {
    background-color: #2a2a2a;
    border: 1px solid #444444;
    selection-background-color: #3a7abf;
}

/* ── Simple View Overlay Buttons ── */
QPushButton#btn_simple_start,
QPushButton#btn_simple_pause,
QPushButton#btn_simple_stop,
QPushButton#btn_simple_estop {
    min-height: 80px;
    font-size: 22pt;
    font-weight: bold;
    border-radius: 6px;
    border: 1px solid #4a4a4a;
}

QPushButton#btn_simple_back {
    min-height: 50px;
    min-width: 140px;
    font-size: 16pt;
    font-weight: bold;
    border-radius: 6px;
    border: 1px solid #3a7abf;
    color: #3a7abf;
    background-color: #1a1a1a;
}

QPushButton#btn_simple_back:hover {
    background-color: #3a7abf;
    color: white;
}

QPushButton#btn_simple_toggle {
    min-height: 50px;
    min-width: 140px;
    font-size: 16pt;
    font-weight: bold;
    border-radius: 6px;
    border: 1px solid #2ecc71; /* Greenish toggle border */
    color: #2ecc71;
    background-color: #1a1a1a;
    margin-left: 10px;
}

QPushButton#btn_simple_toggle:hover {
    background-color: #2ecc71;
    color: white;
}

QPushButton#btn_simple_start[status="running"] {
    background-color: #27ae60;
    color: white;
}
QPushButton#btn_simple_start[status="ready"] {
    border: 2px solid #27ae60;
    color: #2ecc71;
}

QPushButton#btn_simple_pause[status="paused"] {
    background-color: #f39c12;
    color: white;
}
QPushButton#btn_simple_pause[status="running"] {
    border: 2px solid #f39c12;
    color: #f39c12;
}

QPushButton#btn_simple_stop[status="active"] {
    background-color: #c0392b;
    color: white;
}

QPushButton#btn_simple_estop {
    background-color: #8b0000;
    border-color: #cc0000;
    color: #ffffff;
}

/* ── Navigation Sidebar (Floating Card Style) ── */
QPushButton[objectName^="nav_"] {
    background-color: transparent;
    border: 1px solid #444444;
    border-radius: 4px;
    margin: 4px 8px; /* Floating margin */
    min-height: 38px;
    font-size: 11pt;
    font-weight: bold;
    text-align: left;
    padding-left: 16px;
    color: #aaaaaa;
}

QPushButton[objectName^="nav_"]:hover {
    background-color: #383838;
    border-color: #444444;
    color: #ffffff;
}

QPushButton[objectName^="nav_"]:checked {
    background-color: #3a7abf; /* Full active color */
    color: #ffffff;
    border-left: 4px solid #5599dd;
}

/* ── OPT Jalousie Panel ── */
QFrame#optExpandPanel {
    background-color: #1a1a1a;
    border: none;
    border-left: 2px solid #3a7abf;
    margin-right: 2px;
}

QPushButton#btn_opt_sb, 
QPushButton#btn_opt_m1 {
    font-size: 12pt;
    min-height: 40px;
    background: transparent;
    border: 1px solid #333333;
    border-radius: 4px;
    margin: 1px 6px;
    color: #b0b0b0;
}

QPushButton#btn_opt_sb:checked, 
QPushButton#btn_opt_m1:checked {
    background-color: #3a7abf;
    color: white;
    border-color: #5599dd;
}

QPushButton#btn_opt_sb:hover, 
QPushButton#btn_opt_m1:hover {
    background-color: #2a2a2a;
    border-color: #5599dd;
}

/* Specific Machine Buttons */
QPushButton#btn_estop {
    background-color: #8b0000;
    border-color: #cc0000;
    color: #ffffff;
    font-weight: bold;
}
QPushButton#btn_estop:checked {
    background-color: #cc0000;
}

QPushButton#btn_power:checked {
    background-color: #1e7e34;
    border-color: #28a745;
}

/* ── Tabs ── */
QTabWidget::pane {
    border: 1px solid #444444;
    background-color: #2a2a2a;
    border-radius: 4px;
    top: -1px; /* Overlap tab bar border */
}

QTabBar::tab {
    background-color: #252525;
    border: 1px solid #444444;
    border-bottom: none;
    padding: 8px 20px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    color: #999999;
}

QTabBar::tab:selected {
    background-color: #2a2a2a;
    color: #ffffff;
}

QTabBar::tab:hover:!selected {
    background-color: #353535;
}

/* ── Inputs ── */
QLineEdit {
    background-color: #1a1a1a;
    border: 1px solid #444444;
    border-radius: 4px;
    padding: 4px 8px;
    color: #ffffff;
    selection-background-color: #3a7abf;
}

QLineEdit:focus {
    border-color: #3a7abf;
}

/* ── Scrollbars & Sliders ── */
QScrollBar:vertical {
    background: #1e1e1e;
    width: 12px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #444444;
    border-radius: 6px;
    min-height: 30px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background: #555555;
}

/* ── Sliders (Progressive Thick Design) ── */
QSlider:horizontal {
    min-height: 28px;
    background: transparent;
}

QSlider::groove:horizontal {
    height: 24px;
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 4px;
}

QSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #1a4e8e, stop:1 #3a7abf);
    border: 1px solid #333;
    border-radius: 4px;
}

QSlider::handle:horizontal {
    background: #e0e0e0;
    border: 1px solid #555;
    width: 14px;
    height: 24px;
    margin: 0px; 
    border-radius: 4px;
}

QSlider::handle:horizontal:hover {
    background: #ffffff;
    border: 1px solid #3a7abf;
}

QSlider::handle:horizontal:pressed {
    background-color: #3a7abf;
    border: 1px solid #ffffff;
}

/* ── Labels (DRO) ── */
/* ── Jog Buttons (Touch optimized) ── */
QPushButton[objectName*="_jogbutton_"] {
    min-width: 50px;
    min-height: 50px;
    margin: 2px;
    border-radius: 6px;
    background-color: #3d3d3d;
}

QPushButton[objectName*="_jogbutton_"]:hover {
    background-color: #4a4a4a;
    border-color: #2ecc71; /* Green border on hover for axis buttons */
}

QLabel#lbl_dro_x,
QLabel#lbl_dro_y,
QLabel#lbl_dro_z {
    color: #2ecc71;
    background-color: #1a1a1a;
    border: 1px solid #444444;
    border-radius: 4px;
    padding: 2px 8px;
}

/* ── Sidebar Alignment ── */
QStackedWidget#jogDisplay,
QGroupBox#spindleGroup,
QGroupBox#jogBox {
    min-width: 200px;
}

QGroupBox#spindleGroup QLabel {
    font-weight: bold;
    font-size: 12pt;
}

/* Alte Labels entfernt – konsolidiert am Ende des Files */

QProgressBar#spindle_load_bar {
    min-height: 16px; /* Dickere Bar */
    border: 1px solid #444444;
    border-radius: 8px;
    background-color: #1a1a1a;
    text-align: center;
    font-size: 8pt;
    font-weight: bold;
    color: transparent;
}



QPushButton#btn_spindle_fwd,
QPushButton#btn_spindle_rev,
QPushButton#btn_spindle_stop {
    min-height: 52px; /* Touch-freundliche Höhe */
    font-size: 11pt;
    font-weight: bold;
}

/* ── Toolsetter position buttons ── */
QPushButton#btn_set_wechsel_pos,
QPushButton#btn_set_taster_pos {
    border: 1px solid #5599dd;
    color: #7ab3e8;
}
QPushButton#btn_set_wechsel_pos:hover,
QPushButton#btn_set_taster_pos:hover {
    border-color: #7ab3e8;
    color: #ffffff;
    background-color: #2a4a6e;
}

/* ── Backplot ── */
BackplotWidget {
    border: 1px solid #444444;
    border-radius: 4px;
    background-color: #1a1a1a;
}

#backplotToolbar {
    background-color: transparent;
    border: none;
    border-bottom: 1px solid #444444;
}

QPushButton#btn_backplot_view {
    background-color: #2a2a2a;
    color: #aaaaaa;
    border: 1px solid #444444;
    border-radius: 4px;
    font-weight: bold;
    font-size: 11pt;
    padding: 4px 12px;
    min-height: 22px;
}

QPushButton#btn_backplot_view:hover {
    background-color: #3a3a3a;
    color: #ffffff;
}

/* ── Run Controls + E-STOP / POWER group frames ── */
QFrame#runControls,
QFrame#estopPowerGroup {
    border: 1px solid #444444;
    border-radius: 4px;
    background-color: #1a1a1a;
}

/* ── Active G-Codes panel ── */
QFrame#activeGcodesFrame {
    background-color: #2a2a2a;
    border-radius: 4px;
}

/* ── MDI ── */
QLineEdit#mdiEntry {
    background-color: #1e1e1e;
    color: #eeeeee;
    border: 1px solid #555555;
    font-size: 13pt;
    padding: 4px 8px;
    min-height: 40px;
}

QListWidget#mdiHistory {
    background-color: #1a1a1a;
    color: #cccccc;
    border: 1px solid #444444;
    font-size: 12pt;
}

QListWidget#mdiHistory::item:hover { background-color: #2a2a2a; }
QListWidget#mdiHistory::item:selected { background-color: #2d5fa8; color: white; }

/* ── File Browser ── */
QTreeView#fileManagerView {
    background-color: #222222;
    color: #eeeeee;
    font-size: 13pt;
}

QPushButton#btn_nav_up,
QPushButton#btn_nav_home {
    background-color: #333333;
    color: #ffffff;
    font-weight: bold;
    min-height: 30px;
}

QLabel#lbl_current_path {
    color: #aaaaaa;
    font-size: 11pt;
}

QPlainTextEdit#filePreviewArea {
    font-family: Monospace;
    font-size: 11pt;
    background-color: #111111;
    color: #00ff00;
    border: 1px solid #444444;
}

QPushButton#load_gcode_button {
    background-color: #2980b9;
    color: #ffffff;
    border-radius: 4px;
    font-weight: bold;
    font-size: 15pt;
    min-height: 70px;
}

QPushButton#load_gcode_button:hover {
    background-color: #3498db;
}

QPushButton#btn_zoom_in,
QPushButton#btn_zoom_out,
QPushButton#btn_main_zoom_in,
QPushButton#btn_main_zoom_out {
    font-weight: bold;
    font-size: 12pt;
    min-width: 35px;
    min-height: 35px;
    max-width: 35px;
    max-height: 35px;
}

/* ── Breadcrumbs ── */
QWidget#breadcrumb_container {
    background-color: #1a1a1a;
    border: 1px solid #333333;
    border-radius: 4px;
    padding: 2px;
}

QPushButton#breadcrumb_item {
    background: transparent;
    border: none;
    color: #aaaaaa;
    font-weight: bold;
    font-size: 10pt;
    padding: 4px 8px;
    border-radius: 4px;
}

QPushButton#breadcrumb_item:hover {
    background-color: #3a7abf;
    color: #ffffff;
}

QPushButton#btn_find_m6 {
    background-color: #34495e;
    color: #ecf0f1;
    font-weight: bold;
    border: 1px solid #5d6d7e;
    border-radius: 4px;
    padding: 2px 6px;
}

QPushButton#btn_find_m6:hover {
    background-color: #3a7abf; /* ThorCNC Blue */
    border-color: #3174b5;
}

QPushButton#btn_find_m6:disabled {
    background-color: #1a1a1a;
    color: #555555;
    border-color: #333333;
}

QPushButton#btn_save_file {
    background-color: #27ae60;
    color: #ffffff;
    font-weight: bold;
}

QPushButton#btn_save_as_file {
    background-color: #2980b9;
    color: #ffffff;
    font-weight: bold;
}

QPushButton#btn_cancel_edit {
    background-color: #c0392b;
    color: #ffffff;
    font-weight: bold;
}

/* ── Tool Table ── */
QPushButton#btn_reload_tools {
    background-color: #e67e22;
    color: #ffffff;
    font-weight: bold;
}

QPushButton#btn_save_tools {
    background-color: #27ae60;
    color: #ffffff;
    font-weight: bold;
}

QTableWidget#toolTable {
    background-color: #222222;
    color: #eeeeee;
    font-size: 13pt;
    gridline-color: #444444;
}

QTableWidget#toolTable QHeaderView::section {
    background-color: #333333;
    color: #ffffff;
    font-weight: bold;
    font-size: 11pt;
    padding: 4px;
    border: 1px solid #444444;
}

/* ── Probe ── */
QFrame#frm_probe_params,
QFrame#frm_probe_pre_post {
    background-color: #2a2a2a;
    border: 1px solid #444444;
    border-radius: 12px;
    padding: 10px; /* Outer margin for the grid layout */
}

/* Compact Probing Parameter Grid */
QLabel#lbl_probe_params_title {
    font-weight: bold;
    font-size: 11pt;
    color: #aaaaaa;
    margin-bottom: 8px; /* Gap between title and first row */
    letter-spacing: 1px;
}

QFrame#frm_probe_params QLabel[objectName^="lbl_probe_param_"] {
    margin: 2px 0px;
    font-size: 11pt;
    font-weight: bold;
    color: #000000;
    background-color: #e0e0e0;
    border: 1px solid #ffffff;
    border-radius: 4px;
    padding: 6px 12px;
    height: 42px;
    min-height: 42px;
    max-height: 42px;
}

QFrame#frm_probe_params QSpinBox, 
QFrame#frm_probe_params QDoubleSpinBox,
QFrame#frm_probe_params QComboBox {
    margin: 2px 0px;
    padding: 6px 8px;
    font-size: 11pt;
    font-weight: bold;
    color: #000000;
    background-color: #e0e0e0;
    border: 1px solid #999999;
    border-radius: 4px;
    height: 42px;
    min-height: 42px;
    max-height: 42px;
}

QFrame#frm_probe_params QSpinBox:hover, 
QFrame#frm_probe_params QDoubleSpinBox:hover,
QFrame#frm_probe_params QComboBox:hover {
    background-color: #ffffff;
    border-color: #3a7abf;
}

/* Auto Zero Master Button in the grid */
QPushButton#btn_auto_zero_master {
    margin: 2px 0px;
    min-height: 42px;
    font-size: 11pt;
    font-weight: bold;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #3d3d3d, stop:1 #2a2a2a);
    color: #e0e0e0;
    border: 1px solid #4a4a4a;
    border-radius: 4px;
}

QPushButton#btn_auto_zero_master:checked {
    background-color: #3a7abf;
    border-color: #5599dd;
    color: #ffffff;
}

QFrame#frm_probe_grid {
    background-color: #2a2a2a;
    border: 1px solid #555555;
    border-radius: 25px;
}

QFrame#frm_probe_grid QPushButton {
    background-color: #3a3a3a;
    border: 2px solid #555555;
    border-radius: 8px;
}

QFrame#frm_probe_grid QPushButton:hover {
    border-color: #888888;
    background-color: #444444;
}

QFrame#frm_probe_grid QPushButton:checked {
    border-color: #00cc44;
    border-width: 3px;
    background-color: #2a3a2a;
}

QPushButton#btn_probe_clear_x,
QPushButton#btn_probe_clear_y,
QPushButton#btn_probe_clear_all {
    background-color: #3a1a1a;
    color: #ff6666;
    border: 1px solid #cc3333;
    border-radius: 3px;
    font-weight: bold;
}

QPushButton#btn_probe_clear_x:hover,
QPushButton#btn_probe_clear_y:hover,
QPushButton#btn_probe_clear_all:hover {
    background-color: #c0392b;
    color: #ffffff;
}

QLabel#lbl_probe_section_title {
    font-weight: bold;
    font-size: 12pt;
    color: #aaaaaa;
}

/* ── Spindle Display (Digital Focus) ── */
QFrame#spindle_display_frame {
    background-color: #0d1117;
    border: 1px solid #30363d;
    border-radius: 6px;
    min-height: 100px;
}

/* Primary Display for Actual Value (IST) */
QFrame#spindle_display_frame > QLabel#lbl_spindle_ist {
    font-size: 25pt;
    font-weight: bold;
    font-family: monospace;
    color: #58a6ff;
    background: transparent;
    border: none;
    margin-top: 5px;
}

/* Secondary display for Command (CMD) */
QFrame#spindle_display_frame > QLabel#lbl_spindle_soll {
    font-size: 12pt;
    font-weight: normal;
    color: #8b949e;
    background: transparent;
    border: none;
    margin-bottom: 5px;
}

QPushButton#btn_spindle_fwd,
QPushButton#btn_spindle_rev {
    background-color: #21262d;
    border: 1px solid #30363d;
    color: #c9d1d9;
}

QPushButton#btn_spindle_fwd:hover,
QPushButton#btn_spindle_rev:hover {
    background-color: #30363d;
}

QPushButton#btn_spindle_stop {
    background-color: #21262d;
    border: 1px solid #30363d;
    color: #f85149;
}

QPushButton#btn_spindle_stop:hover {
    background-color: #da3633;
    color: white;
}

QProgressBar#spindle_load_bar[loadState="normal"]::chunk { background-color: #2ea043; border-radius: 7px; }
QProgressBar#spindle_load_bar[loadState="warning"]::chunk { background-color: #d29922; border-radius: 7px; }
QProgressBar#spindle_load_bar[loadState="critical"]::chunk { background-color: #f85149; border-radius: 7px; }

/* ── DRO ── */
QLabel#section_title {
    font-size: 16pt;
    font-weight: bold;
    color: #dddddd;
}

QLabel[objectName="dro_header"] {
    font: bold 12pt "Bebas Kai";
    color: #eeeeec;
    padding: 0 4px;
}

QLabel[objectName="dro_axis_label"] {
    font: bold 20pt "Bebas Kai";
    color: #eeeeec;
}

QLabel[objectName="dro_work"] {
    font: 18pt "Bebas Kai";
    color: #00dd55;
    background-color: rgb(25,28,30);
    border-radius: 3px;
    padding: 2px 8px;
}

QLabel[objectName="dro_machine"] {
    font: 18pt "Bebas Kai";
    color: #aaaaaa;
    background-color: rgb(25,28,30);
    border-radius: 3px;
    padding: 2px 8px;
}

QLabel[objectName="dro_dtg"] {
    font: 18pt "Bebas Kai";
    color: #e67e22;
    background-color: rgb(25,28,30);
    border-radius: 3px;
    padding: 2px 8px;
}

QComboBox#wcsCombo {
    font: bold 12pt "Bebas Kai";
    color: #eeeeec;
    background: rgb(60,68,70);
    border: 1px solid rgb(186,189,182);
    border-radius: 4px;
    padding: 0 6px;
    min-height: 32px;
}

QComboBox#wcsCombo::drop-down { border: none; }
QComboBox#wcsCombo QAbstractItemView {
    background: rgb(46,52,54);
    color: #eeeeec;
    selection-background-color: rgb(78,154,6);
}

/* ── Slider overlay labels (transparent so slider shows through) ── */
QLabel#feed_override_status,
QLabel#spindle_override_status,
QLabel#rapid_override_status,
QLabel#v_override_status,
QLabel#jog_vel_label {
    background: transparent;
    padding-left: 6px;
}

/* ── Status Log ── */
QListWidget#status_log {
    font-family: monospace;
    font-size: 11px;
}

QListWidget#status_log::item {
    padding: 3px 6px;
    border-bottom: 1px solid #333333;
}

/* ── Tool Labels (Status Bar) ── */
QLabel#label_tool_nr {
    background-color: #1a1a1a;
    color: #ffffff;
    font-size: 22px;
    font-weight: bold;
    border: 1px solid #444444;
    border-radius: 3px;
    padding: 2px 8px;
}

QPushButton#btn_m6_change {
    background-color: #2d5fa8;
    color: white;
    font-weight: bold;
    font-size: 11px;
    border-radius: 3px;
    padding: 2px 6px;
    max-width: 55px;
}

QLabel#tool_dia_label,
QLabel#tool_len_label {
    background-color: #1a1a1a;
    color: #cccccc;
    border: 1px solid #444444;
    border-radius: 3px;
    font-size: 16px;
    font-weight: bold;
    padding: 2px 8px;
}

QLabel#tool_comment_label {
    color: #aaaaaa;
    font-size: 14px;
    padding: 2px 4px;
}

/* ── Settings tabs ── */
QTabWidget#settings_tabs > QTabBar::tab {
    height: 32px;
    width: 120px;
    margin: 0px 2px 0px 0px;
    padding: 4px 12px;
    border: 1px solid #555555;
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    background: #2a2a2a;
    color: #aaaaaa;
    font-weight: bold;
}

QTabWidget#settings_tabs > QTabBar::tab:selected {
    background: #1e5a8a;
    color: white;
}

QTabWidget#settings_tabs > QTabBar::tab:hover:!selected {
    background: #3a3a3a;
}

QLabel#backplot_unavailable_label {
    color: #888888;
    border: 1px dashed #555555;
}

/* ── Offsets Table ── */
QTableWidget#offsetsTable {
    background-color: #252525;
    color: #eeeeee;
    font-size: 13pt;
    gridline-color: #333333;
    border: 1px solid #444444;
    border-radius: 4px;
}

QTableWidget#offsetsTable QHeaderView::section {
    background-color: #1e1e1e;
    color: #888888;
    font-size: 11pt;
    font-weight: bold;
    border: none;
    border-bottom: 1px solid #444444;
    border-right: 1px solid #2a2a2a;
    padding: 6px;
}

QTableWidget#offsetsTable::item {
    padding: 4px 10px;
    border-bottom: 1px solid #222222;
}

QPushButton#wcs_clear_btn {
    background-color: #3a1a1a;
    color: #eeeeee;
    border-radius: 3px;
    border: none;
    font-weight: bold;
    font-size: 10pt;
}

QPushButton#wcs_clear_btn:hover {
    background-color: #c0392b;
    color: white;
}

/* ── Probe Grid Buttons ── */
QPushButton#probe_grid_btn {
    background-color: #3a3a3a;
    border: 2px solid #555555;
    border-radius: 8px;
}

QPushButton#probe_grid_btn:hover {
    border-color: #888888;
    background-color: #444444;
}

QPushButton#probe_grid_btn:checked {
    border-color: #00cc44;
    border-width: 3px;
    background-color: #2a3a2a;
}

QPushButton#btn_probe_center_mode {
    background-color: #333333;
    border: 2px solid #555555;
    border-radius: 6px;
    font-weight: bold;
    color: #aaaaaa;
}

QPushButton#btn_probe_center_mode:checked {
    background-color: #2a3a2a;
    border-color: #00cc44;
    color: #00cc44;
}

/* ── Tool-Timer / Status (unten rechts) ── */
#time_display {
    font-family: 'Bebas Kai';
    font-size: 14pt;
    color: #cc0000;
    font-weight: bold;
}

/* ── Optional Options Dialog ── */
QDialog#OptOptionsDialog {
    min-width: 350px;
}

QPushButton#btn_single_block,
QPushButton#btn_m1 {
    font-size: 12pt;
    min-height: 70px;
}

QPushButton#btn_single_block[active="true"],
QPushButton#btn_m1[active="true"] {
    background-color: #3a7abf;
    color: white;
    border: 1px solid #5599dd;
}

QPushButton#btn_close {
    border: 1px solid #666666;
    color: #aaaaaa;
}

/* ── M6 Tool Change Dialog (Manual Tool Load) ── */
QFrame#m6Container {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #25262b, stop:1 #1a1b1e);
    border: 2px solid #f0883e;
    border-radius: 12px;
}

QLabel#m6Header {
    color: #f0883e;
    font-size: 14pt;
    font-weight: bold;
    letter-spacing: 2px;
    padding-bottom: 5px;
    border-bottom: 1px solid #333333;
}

QFrame#m6ToolFrame {
    background-color: #1a1b1e;
    border: 1px solid #333333;
    border-radius: 8px;
    margin: 10px 0;
}

QLabel#m6ToolNumLarge {
    color: #f0883e;
    font-size: 72pt;
    font-weight: 900;
    font-family: 'Bebas Kai', 'DejaVu Sans', sans-serif;
}

QLabel#m6ToolDescription {
    color: #ffffff;
    font-size: 20pt;
    font-weight: bold;
    font-style: italic;
    padding: 15px;
    background-color: #25262b;
    border: 1px solid #3d3d3d;
    border-radius: 6px;
}

QLabel#m6ToolSpec {
    color: #aaaaaa;
    font-size: 12pt;
    background-color: #333333;
    padding: 6px 16px;
    border: 1px solid #444444;
    border-radius: 20px; /* Badge style */
}

QPushButton#m6ConfirmBtn {
    background-color: #2ea043;
    color: white;
    font-size: 16pt;
    font-weight: bold;
    border: none;
    border-radius: 8px;
    padding: 10px;
}

QPushButton#m6ConfirmBtn:hover {
    background-color: #3fb950;
    border: 1px solid #a4ef0a;
}

QPushButton#m6ConfirmBtn:pressed {
    background-color: #238636;
    padding-top: 14px; /* Subtle physical feedback */
}

/* ── Tool Selection Dialog (Search/Select) ── */
QFrame#toolDialogContainer {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #25262b, stop:1 #1a1b1e);
    border: 2px solid #3a7abf; /* Blue accent instead of orange */
    border-radius: 12px;
}

QLabel#toolDialogHeader {
    color: #3a7abf;
    font-size: 16pt;
    font-weight: bold;
    letter-spacing: 1px;
    padding-bottom: 10px;
    border-bottom: 2px solid #333333;
    margin-bottom: 5px;
}

QLineEdit#toolSearchInput {
    background-color: #25262b;
    border: 2px solid #3a7abf;
    border-radius: 6px;
    padding: 10px;
    font-size: 13pt;
    color: #ffffff;
}

QTableWidget#toolSelectionTable {
    background-color: #1a1b1e;
    alternate-background-color: #222327;
    gridline-color: #333333;
    border: 1px solid #444444;
    font-size: 12pt;
}

QTableWidget#toolSelectionTable QHeaderView::section {
    background-color: #2a2a2a;
    color: #3a7abf;
    padding: 8px;
    font-weight: bold;
    border: none;
    border-bottom: 2px solid #3a7abf;
}

QTableWidget#toolSelectionTable::item {
    padding: 8px;
}

QTableWidget#toolSelectionTable::item:selected {
    background-color: #3a7abf;
    color: white;
}

QPushButton#btnToolConfirm {
    background-color: #3a7abf;
    min-height: 45px;
    font-size: 12pt;
    border-radius: 6px;
}

QPushButton#btnToolCancel {
    background-color: #3d3d3d;
    min-height: 45px;
    font-size: 11pt;
    color: #aaaaaa;
    border-radius: 6px;
}

QPushButton#btnToolCancel:hover {
    background-color: #4a4a4a;
    color: #ffffff;
}
