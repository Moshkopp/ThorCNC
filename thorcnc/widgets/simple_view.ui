     <!-- Row 2: Y -->
     <item row="2" column="0"><widget class="QLabel" name="lbl_row_y"><property name="text"><string>Y</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignHCenter|Qt::AlignmentFlag::AlignVCenter</set></property></widget></item>
     <item row="2" column="1"><widget class="QLabel" name="lbl_wcs_y"><property name="text"><string>+0.000</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignHCenter|Qt::AlignmentFlag::AlignVCenter</set></property></widget></item>
