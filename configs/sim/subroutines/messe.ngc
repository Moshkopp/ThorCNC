o<messe> sub

O<before_toolsetter> call

(--- 1. CONFIGURATION FROM HAL-PINS ThorCNC GUI ---)
#<wechsel_x>           = #<_hal[thorcnc.ts-wechsel-x]>
#<wechsel_y>           = #<_hal[thorcnc.ts-wechsel-y]>
#<wechsel_z>           = #<_hal[thorcnc.ts-wechsel-z]>
#<spindle_zero_height> = #<_hal[thorcnc.ts-spindle-zero]>
#<touch_x>             = #<_hal[thorcnc.ts-x]>
#<touch_y>             = #<_hal[thorcnc.ts-y]>
#<touch_z>             = #<_hal[thorcnc.ts-z]>
#<max_probe>           = #<_hal[thorcnc.ts-max-probe]>
#<search_vel>          = #<_hal[thorcnc.ts-search-vel]>
#<probe_vel>           = #<_hal[thorcnc.ts-probe-vel]>
#<retract>             = #<_hal[thorcnc.ts-retract]>

(--- 2. CLEANUP ---)
M5 M9
G90
G53 G0 Z#<wechsel_z>
G92.1
G49

(--- 3. REMEMBER WCS ---)
#1900 = #<_coord_system>

o500 if [#<_current_tool> EQ #<_selected_tool>]
  (debug, Tool already in spindle - just measure)
o500 else
  (--- 4. TOOL CHANGE POSITION ---)
  G53 G0 X#<wechsel_x> Y#<wechsel_y>
  (--- 5. TOOL CHANGE ---) 
  M6 T#<_selected_tool>
o500 endif

(--- 6. APPROACH TOOLSETTER ---)
G90 G53 G0 Z#<wechsel_z>
G53 G0 X#<touch_x> Y#<touch_y>

(Safe approach above toolsetter)
#<safe_approach> = [#<touch_z> + 10.0]
o110 if [#<safe_approach> GT 0]
  #<safe_approach> = 0
o110 endif
G53 G0 Z#<safe_approach>

(--- 6b. GROSSWERKZEUG-VERSATZ ---)
(Wenn Werkzeug-Dia > Kontaktflaeche: Schneide ueber Taster-Mitte verschieben)
#<_lte_enable>   = #<_hal[thorcnc.ts-large-tool-enable]>
#<_lte_contact>  = #<_hal[thorcnc.ts-contact-diameter]>
#<_lte_dir_x>    = #<_hal[thorcnc.ts-offset-dir-x]>
#<_lte_dir_y>    = #<_hal[thorcnc.ts-offset-dir-y]>
#<_lte_tool_dia> = #5413
#<_lte_offset>   = 0.0

o200 if [#<_lte_enable> AND [#<_lte_tool_dia> GT #<_lte_contact>]]
  #<_lte_offset> = [#<_lte_tool_dia> / 2.0]
  (debug, Grosse Werkzeug erkannt: Dia=#<_lte_tool_dia> Versatz=#<_lte_offset>mm)
  G91
  G0 X[#<_lte_offset> * #<_lte_dir_x>] Y[#<_lte_offset> * #<_lte_dir_y>]
  G90
o200 endif

(--- 7. MEASUREMENT PROCESS IN G59.3 ---)
G59.3
G49
G10 L1 P#<_selected_tool> Z0

G91
(Fast probe)
G38.2 Z#<max_probe> F#<search_vel>
G1 Z#<retract> F#<search_vel>
(Fine probe)
G38.2 Z[#<retract> * -2] F#<probe_vel>
#<touch_result> = #5063
(Clearance move after measure)
G1 Z#<retract> F#<search_vel>

(--- 8. CALCULATE OFFSET ---)
#<new_tool_length> = [ABS[#<spindle_zero_height> + #<touch_result>]]
G90
G10 L1 P#<_selected_tool> Z#<new_tool_length>
G43 H#<_selected_tool>
(debug, Tool length: #<new_tool_length> mm)

(--- 8b. GROSSWERKZEUG-VERSATZ RUECKGAENGIG ---)
o201 if [#<_lte_enable> AND [#<_lte_offset> GT 0]]
  G91
  G0 X[-#<_lte_offset> * #<_lte_dir_x>] Y[-#<_lte_offset> * #<_lte_dir_y>]
  G90
o201 endif

(--- 9. COMPLETION ---)
G53 G0 Z#<wechsel_z>

(Restore WCS)
o100 if [#1900 EQ 540]
  G54
o100 endif
o101 if [#1900 EQ 550]
  G55
o101 endif
o102 if [#1900 EQ 560]
  G56
o102 endif
o103 if [#1900 EQ 570]
  G57
o103 endif
o104 if [#1900 EQ 580]
  G58
o104 endif

T#5400 G43 H#5400

O<after_toolsetter> call
o<messe> endsub
M2
