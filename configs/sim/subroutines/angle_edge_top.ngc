( ThorCNC - Edge Angle Top - Probe Y- )
( #1: Meas Dist, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid, #12: XY Cl, #13: Step Off )

O<angle_edge_top> sub
    ( 1. Initialization )
    G90 G17 G40 G21
    G92.1 ( Cancel any lingering G92 offsets )
    M50 P0 ( Disable Feed Override )

    ( Clear rotation before measuring to get absolute angle )
    G10 L2 P0 R0

    ( 2. Z-Probe to find surface )
    G91
    G38.2 Z-[#4] F#5
    G1 Z#13 F#11 ( Step Off )
    G38.2 Z-[#13 * 2] F#6 ( Fine Probe )
    ( Tool is now physically at probed surface )

    G90 ( From here on Z is absolute in current WCS )

    ( 3. Capture surface in current WCS )
    #<z_surface> = #5063
    #<z_clearance> = [#<z_surface> + #7]
    #<z_plunge>    = [#<z_surface> - #8]

    G1 Z#<z_clearance> F#11 ( Absolute raise to clearance )

    ( 4. Common variables )
    #<start_x> = #5420
    #<start_y> = #5421
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    #<dist> = #1

    ( 5. Probe Point 1 )
    G1 Y[#<start_y> + #12] F#<rapid>
    G1 Z#<z_plunge> F#<rapid> ( Absolute plunge to probing depth )
    G91
    G38.2 Y-[#12 + #3] F#5
    G1 Y[#13] F#<rapid>
    G38.2 Y-[#13 * 1.5] F#6
    #<p1_x> = #5061
    #<p1_y> = #5062
    G1 Y[#13] F#<rapid>
    G90
    G1 Z#<z_clearance> F#<rapid> ( Absolute raise to clearance )

    ( 6. Move to Point 2 )
    G1 X[#<start_x> + #<dist>] Y#<start_y> F#<rapid>

    ( 7. Probe Point 2 )
    G1 Y[#<start_y> + #12] F#<rapid>
    G1 Z#<z_plunge> F#<rapid> ( Absolute plunge to probing depth )
    G91
    G38.2 Y-[#12 + #3] F#5
    G1 Y[#13] F#<rapid>
    G38.2 Y-[#13 * 1.5] F#6
    #<p2_x> = #5061
    #<p2_y> = #5062
    G1 Y[#13] F#<rapid>
    G90
    G1 Z#<z_clearance> F#<rapid> ( Absolute raise to clearance )

    ( 8. Calculate Angle )
    #<dx> = [#<p2_x> - #<p1_x>]
    #<dy> = [#<p2_y> - #<p1_y>]

    #<angle> = [ ATAN[#<dy>]/[#<dx>] ]

    ( 9. Apply Rotation )
    G10 L2 P0 R#<angle>

    ( 10. Move back to start )
    G1 X#<start_x> Y#<start_y> F#<rapid>

    ( Publish results to GUI )
    #1000 = 71
    #1010 = #<p1_x>
    #1011 = #<p1_y>
    #1012 = #<z_surface>
    #1013 = #<p2_x>
    #1014 = #<p2_y>
    #1040 = #<angle>
    #1001 = [#1001 + 1] ( counter - last )

    M50 P1 ( Re-enable Feed Override )

O<angle_edge_top> endsub
M2
