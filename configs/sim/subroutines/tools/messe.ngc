o<messe> sub

(--- 1. KONFIGURATION AUS HAL-PINS ThorCNC GUI ---)
#<wechsel_x>           = #<_hal[thorcnc.ts-wechsel-x]>
#<wechsel_y>           = #<_hal[thorcnc.ts-wechsel-y]>
#<wechsel_z>           = #<_hal[thorcnc.ts-wechsel-z]>
#<spindle_zero_height> = #<_hal[thorcnc.ts-spindle-zero]>
#<touch_x>             = #<_hal[thorcnc.ts-x]>
#<touch_y>             = #<_hal[thorcnc.ts-y]>
#<touch_z>             = #<_hal[thorcnc.ts-z]>
#<max_probe>           = #<_hal[thorcnc.ts-max-probe]>
#<search_vel>          = #<_hal[thorcnc.ts-search-vel]>
#<probe_vel>           = #<_hal[thorcnc.ts-probe-vel]>
#<retract>             = #<_hal[thorcnc.ts-retract]>

(--- 2. CLEANUP ---)
M5 M9
G90
G53 G0 Z#<wechsel_z>
G92.1
G49

(--- 3. NP MERKEN ---)
#1900 = #<_coord_system>

o500 if [#<_current_tool> EQ #<_selected_tool>]
  (debug, Tool bereits in der Spindel - nur messen)
o500 else
  (--- 4. WECHSELPOSITION ---)
  G53 G0 X#<wechsel_x> Y#<wechsel_y>
  (--- 5. WERKZEUGWECHSEL ---) 
  M6 T#<_selected_tool>
o500 endif

(--- 6. ANFAHRT TOOLSETTER ---)
G90 G53 G0 Z#<wechsel_z>
G53 G0 X#<touch_x> Y#<touch_y>

(Sicher ueber Taster absenken)
#<safe_approach> = [#<touch_z> + 10.0]
o110 if [#<safe_approach> GT 0]
  #<safe_approach> = 0
o110 endif
G53 G0 Z#<safe_approach>

(--- 7. MESSVORGANG IN G59.3 ---)
G59.3
G49
G10 L1 P#<_selected_tool> Z0

G91
(Grob antasten)
G38.2 Z#<max_probe> F#<search_vel>
G1 Z#<retract> F#<search_vel>
(Fein antasten)
G38.2 Z[#<retract> * -2] F#<probe_vel>
#<touch_result> = #5063
(Freifahren nach Messen)
G1 Z#<retract> F#<search_vel>

(--- 8. OFFSET BERECHNEN ---)
#<new_tool_length> = [ABS[#<spindle_zero_height> + #<touch_result>]]
G90
G10 L1 P#<_selected_tool> Z#<new_tool_length>
G43 H#<_selected_tool>
(debug, Werkzeuglaenge: #<new_tool_length> mm)

(--- 9. ABSCHLUSS ---)
G53 G0 Z#<wechsel_z>

(NP wiederherstellen)
o100 if [#1900 EQ 540]
  G54
o100 endif
o101 if [#1900 EQ 550]
  G55
o101 endif
o102 if [#1900 EQ 560]
  G56
o102 endif
o103 if [#1900 EQ 570]
  G57
o103 endif
o104 if [#1900 EQ 580]
  G58
o104 endif

T#5400 G43 H#5400
o<messe> endsub
M2
