( ThorCNC - Inside Center Finder X AXIS )
( Args: )
( #1: X Length )
( #3: Max XY Search Distance )
( #4: Max Z Search Distance )
( #5: Search Velocity )
( #6: Probe Velocity )
( #7: Z Clearance / Retract )
( #8: Probe Depth - Distance below Z0 )
( #9: Auto Zero - 1=ON, 0=OFF )

O<inside_rect_x> sub
    ( Save current state )
    M68 E0 Q0
    
    ( 1. Z-Probe at center )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<start_x> = #5420
    
    ( 2. X-Center Finding )
    ( Probe X- side )
    G1 Z-[#8] F[#5 * 2]
    G91
    G38.2 X-#3 F#5
    #<x1> = #5061
    G0 X#7
    G38.2 X-[#7 * 1.5] F#6
    #<x1> = #5061
    G90
    G0 X#<start_x>

    ( Probe X+ side )
    G91
    G38.2 X#3 F#5
    #<x2> = #5061
    G0 X-#7
    G38.2 X[#7 * 1.5] F#6
    #<x2> = #5061
    G90
    G0 X#<start_x>
    
    #<x_center> = [[#<x1> + #<x2>] / 2]

    ( 3. Final Positioning )
    G0 X#<x_center>
    O102 if [#9 GT 0.5]
        G10 L20 P0 X0
    O102 endif
    G0 Z#7
    
O<inside_rect_x> endsub
M2
