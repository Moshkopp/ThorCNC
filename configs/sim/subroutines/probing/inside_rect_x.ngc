( ThorCNC - Inside Rect Pocket Center X )
( #1: Expected Width X, #3: Max Search, #4: Max Z Search, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid, #12: XY Cl, #13: Step Off )

O<inside_rect_x> sub
    ( 1. Initialization )
    G90 G17 G40 G21
    G92.1 ( Cancel any lingering G92 offsets )
    M50 P0 ( Disable Feed Override )

    ( 2. Z-Probe to find top )
    G91
    G38.2 Z-[#4] F#5
    G1 Z#13 F#11
    G38.2 Z-[#13 * 2] F#6
    ( Tool is now physically at probed surface )

    G90 ( From here on Z is absolute in current WCS )

    ( 3. Capture surface in current WCS )
    #<z_surface> = #5063
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0 ( Zero Z in WCS at surface )
        #<z_surface> = 0 ( WCS shifted - surface is now at 0 )
    O101 endif

    #<z_clearance> = [#<z_surface> + #7]
    #<z_plunge>    = [#<z_surface> - #8]

    G1 Z#<z_clearance> F#11 ( Absolute raise to clearance )

    ( 4. Common variables )
    #<start_x> = #5420
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    #<jump_x> = [[#1 / 2] + #12]

    ( 5. Move to Center & Plunge )
    G91
    G1 X#<jump_x> F#<rapid>
    G90
    G1 Z#<z_plunge> F#<rapid> ( Absolute plunge to probing depth )
    #<center_x> = #5420

    ( 6. X-Center Finding )
    G91
    G38.2 X-[[#1 / 2] + #3] F#5
    G1 X#13 F#<rapid>
    G38.2 X-[#13 * 1.5] F#6
    #<x1> = #5061
    G1 X#13 F#<rapid>
    G90
    G1 X#<center_x> F#<rapid>

    G91
    G38.2 X[[#1 / 2] + #3] F#5
    G1 X-[#13] F#<rapid>
    G38.2 X[#13 * 1.5] F#6
    #<x2> = #5061
    G1 X-[#13] F#<rapid>
    G90

    #<x_center> = [[#<x1> + #<x2>] / 2]

    ( 7. Final Positioning & Zeroing )
    G1 X#<x_center> F#<rapid>
    O102 if [#9 GT 0.5]
        G10 L20 P0 X0
    O102 endif
    G1 Z#<z_clearance> F#<rapid> ( Absolute raise to clearance )

    ( Compute measured X width - pocket probe touches inside )
    #<meas_width_x> = [#<x2> - #<x1> + #<dia>]

    ( Publish results to GUI )
    #1000 = 61
    #1012 = #<z_surface>
    #1020 = #<x_center>
    #1030 = #<meas_width_x>
    #1001 = [#1001 + 1] ( counter - last )

    M50 P1 ( Re-enable Feed Override )

O<inside_rect_x> endsub
M2
