( ThorCNC - Inside Center Finder X-Axis Rect )
( #1: X Length, #3: Max XY Search, #4: Max Z Search, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid )

O<inside_rect_x> sub
    ( 1. Z-Probe at center )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<start_x> = #5420
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    
    ( Move to probe depth )
    G1 Z-[#<rad> + #8] F#<rapid>

    ( 2. X-Center Finding )
    ( Probe X- side )
    G91
    G38.2 X-[#3] F#5
    #<x1> = #5061
    G1 X#7 F#<rapid>
    G38.2 X-[#7 * 1.5] F#6
    #<x1> = #5061
    G90
    G1 X#<start_x> F#<rapid>
    
    ( Probe X+ side )
    G91
    G38.2 X#3 F#5
    #<x2> = #5061
    G1 X-#7 F#<rapid>
    G38.2 X[#7 * 1.5] F#6
    #<x2> = #5061
    G90
    
    #<x_center> = [[#<x1> + #<x2>] / 2]

    ( 3. Final Positioning & Zeroing )
    G1 X#<x_center> F#<rapid>
    O102 if [#9 GT 0.5]
        G10 L20 P0 X0
    O102 endif
    G1 Z#7 F#<rapid>

O<inside_rect_x> endsub
M2