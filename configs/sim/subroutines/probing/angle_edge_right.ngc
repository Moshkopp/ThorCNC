( ThorCNC - Edge Angle Right (Probe X-) )
( #1: Meas Dist, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid, #12: XY Cl, #13: Step Off )

O<angle_edge_right> sub
    ( 1. Initialization )
    G90 G17 G40 G21
    
    ( Clear rotation before measuring to get absolute angle )
    G10 L2 P0 R0
    
    ( 2. Z-Probe )
    G91
    G38.2 Z-[#4] F#5
    G1 Z#13 F#11 ( Step Off )
    G38.2 Z-[#13 * 2] F#6 ( Fine Probe )
    G90
    G1 Z#7 F#11 ( Move to Z Clearance )

    #<start_x> = #5420
    #<start_y> = #5421
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    #<dist> = #1
    
    ( 3. Probe Point 1 )
    G1 X[#<start_x> + #12] F#<rapid>
    G1 Z-[#<rad> + #8] F#<rapid>
    G91
    G38.2 X-[#12 + #3] F#5
    G1 X[#13] F#<rapid>
    G38.2 X-[#13 * 1.5] F#6
    #<p1_x> = #5061
    #<p1_y> = #5062
    G1 X[#13] F#<rapid>
    G90
    G1 Z#7 F#<rapid>
    
    ( 4. Move to Point 2 )
    G1 X#<start_x> Y[#<start_y> + #<dist>] F#<rapid>
    
    ( 5. Probe Point 2 )
    G1 X[#<start_x> + #12] F#<rapid>
    G1 Z-[#<rad> + #8] F#<rapid>
    G91
    G38.2 X-[#12 + #3] F#5
    G1 X[#13] F#<rapid>
    G38.2 X-[#13 * 1.5] F#6
    #<p2_x> = #5061
    #<p2_y> = #5062
    G1 X[#13] F#<rapid>
    G90
    G1 Z#7 F#<rapid>
    
    ( 6. Calculate Angle )
    #<dx> = [#<p2_x> - #<p1_x>]
    #<dy> = [#<p2_y> - #<p1_y>]
    
    #<angle> = [ -1 * ATAN[#<dx>]/[#<dy>] ]
    
    ( 7. Apply Rotation )
    G10 L2 P0 R#<angle>
    
    ( 8. Move back to start )
    G1 X#<start_x> Y#<start_y> F#<rapid>

O<angle_edge_right> endsub
M2
