( ThorCNC - Edge Angle Right - Probe X- )
( #1: Meas Dist, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid, #12: XY Cl, #13: Step Off )

O<angle_edge_right> sub
    ( 1. Initialization )
    G90 G17 G40 G21

    ( Clear rotation before measuring to get absolute angle )
    G10 L2 P0 R0

    ( 2. Z-Probe )
    G91
    G38.2 Z-[#4] F#5
    G1 Z#13 F#11 ( Step Off )
    G38.2 Z-[#13 * 2] F#6 ( Fine Probe )
    ( Tool is now physically at probed surface )
    G1 Z#7 F#11 ( Relative up to Z clearance above surface )

    G90
    #<start_x> = #5420
    #<start_y> = #5421
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    #<dist> = #1
    #<plunge_delta> = [#7 + #<rad> + #8] ( Distance from clearance down to probing depth )

    ( 3. Probe Point 1 )
    G1 X[#<start_x> + #12] F#<rapid>
    G91
    G1 Z-#<plunge_delta> F#<rapid>
    G38.2 X-[#12 + #3] F#5
    G1 X[#13] F#<rapid>
    G38.2 X-[#13 * 1.5] F#6
    #<p1_x> = #5061
    #<p1_y> = #5062
    G1 X[#13] F#<rapid>
    G1 Z#<plunge_delta> F#<rapid> ( Raise Z back to clearance )
    G90

    ( 4. Move to Point 2 )
    G1 X#<start_x> Y[#<start_y> + #<dist>] F#<rapid>

    ( 5. Probe Point 2 )
    G1 X[#<start_x> + #12] F#<rapid>
    G91
    G1 Z-#<plunge_delta> F#<rapid>
    G38.2 X-[#12 + #3] F#5
    G1 X[#13] F#<rapid>
    G38.2 X-[#13 * 1.5] F#6
    #<p2_x> = #5061
    #<p2_y> = #5062
    G1 X[#13] F#<rapid>
    G1 Z#<plunge_delta> F#<rapid> ( Raise Z back to clearance )
    G90

    ( 6. Calculate Angle )
    #<dx> = [#<p2_x> - #<p1_x>]
    #<dy> = [#<p2_y> - #<p1_y>]

    #<angle> = [ -1 * ATAN[#<dx>]/[#<dy>] ]

    ( 7. Apply Rotation )
    G10 L2 P0 R#<angle>

    ( 8. Move back to start )
    G1 X#<start_x> Y#<start_y> F#<rapid>

O<angle_edge_right> endsub
M2
