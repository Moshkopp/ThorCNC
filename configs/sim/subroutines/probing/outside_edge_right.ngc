( ThorCNC - Outside Right Edge )
( #1: Edge Width, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid )

O<outside_edge_right> sub
    ( 1. Z-Probe )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<start_x> = #5420
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    
    ( 2. X-Probe from right )
    G91
G1 X#1 F#<rapid>
    G90
G1 Z-[#<rad> + #8] F#<rapid>
    G91
    G38.2 X-#3 F#5
    #<x_hit> = #5061
G1 X#7 F#<rapid>
    G38.2 X-[#7 * 1.5] F#6
    #<x_hit> = #5061
    G90
G1 Z#7 F#<rapid>
    
    ( 3. Final Position & Zeroing )
G1 X#<start_x> F#<rapid>
    O102 if [#9 GT 0.5]
        ( Wall is at x_hit - radius )
        G10 L20 P0 X[#<start_x> - [#<x_hit> - #<rad>]]
    O102 endif
O<outside_edge_right> endsub
M2
