( ThorCNC - Outside Right Edge )
( #1: Edge Width, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero )

O<outside_edge_right> sub
    ( 1. Z-Probe )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<start_x> = #5420
    #<rad> = [#5410 / 2]
    
    ( 2. X-Probe from right )
    G91
    G0 X#1
    G90
    G1 Z-[#8] F[#5 * 2]
    G91
    G38.2 X-#3 F#5
    #<x_hit> = #5061
    G0 X#7
    G38.2 X-[#7 * 1.5] F#6
    #<x_hit> = #5061
    G90
    G0 Z#7
    
    ( 3. Final Position & Zeroing )
    G0 X#<start_x>
    O102 if [#9 GT 0.5]
        ( Wall is at x_hit - radius )
        G10 L20 P0 X[#<start_x> - [#<x_hit> - #<rad>]]
    O102 endif
O<outside_edge_right> endsub
M2
