( ThorCNC - Center Finder Rectangular Boss - Y AXIS ONLY )
( Args: )
( #1: X Length - NOT USED in this version, but kept for signature compatibility )
( #2: Y Length )
( #3: Max XY Search Distance )
( #4: Max Z Search Distance )
( #5: Search Velocity )
( #6: Probe Velocity )
( #7: Z Clearance / Retract )
( #8: Probe Depth - Distance below Z0 )
#9: Auto Zero - 1=ON, 0=OFF )
( #10: Probe Diameter )
( #11: Probe Rapid )

O<center_rect_y> sub
    ( Save current state )
    M68 E0 Q0 ( Placeholder for any needed HAL sync )
    
    ( 1. Z-Probe )
    G91 ( Incremental mode )
    G38.2 Z-[#4] F#5 ( Search Z- )
    G0 Z#7 ( Retract )
    G38.2 Z-[#7 * 1.5] F#6 ( Fine probe )
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0 ( Set Z Work Offset to 0 )
    O101 endif
    G0 Z#7 ( Safe retract )
    G90 ( Absolute mode )

    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]

    ( 2. Y-Center Finding )
    #<search_dist_y> = [[#2 / 2] + #3]
    
    ( Probe Y- side )
G1 Y-[#<search_dist_y>] F#<rapid>
G1 Z-[#<rad> + #8] F#<rapid>
    G91
    G38.2 Y#3 F#5 ( Search Y+ )
    #<y1> = #5062 ( #5062 is Y position )
G1 Y-[#7] F#<rapid>
    G38.2 Y[#7 * 1.5] F#6
    #<y1> = #5062
    G90
G1 Z#7 F#<rapid>

    ( Probe Y+ side )
G1 Y[#<search_dist_y>] F#<rapid>
G1 Z-[#<rad> + #8] F#<rapid>
    G91
    G38.2 Y-#3 F#5 ( Search Y- )
    #<y2> = #5062
G1 Y#7 F#<rapid>
    G38.2 Y-[#7 * 1.5] F#6
    #<y2> = #5062
    G90
G1 Z#7 F#<rapid>
    
    #<y_center> = [[#<y1> + #<y2>] / 2]

    ( 3. Final Positioning )
G1 Y#<y_center> F#<rapid>
    O102 if [#9 GT 0.5]
        G10 L20 P0 Y0 ( Zero work offset for Y )
    O102 endif
    
    ( Return to safe height )
G1 Z#7 F#<rapid>
    
O<center_rect_y> endsub
M2
