( ThorCNC - Inside Center Finder Circular Pocket )
( Args: )
( #1: Diameter )
( #3: Max XY Search Distance )
( #4: Max Z Search Distance )
( #5: Search Velocity )
( #6: Probe Velocity )
( #7: Z Clearance / Retract )
( #8: Probe Depth - Distance below Z0 )
#9: Auto Zero - 1=ON, 0=OFF )
( #10: Probe Diameter )
( #11: Probe Rapid )

O<inside_round> sub
    ( Save current state )
    M68 E0 Q0
    
    ( 1. Z-Probe at center )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    #<start_x> = #5420
    #<start_y> = #5421
    
    ( 2. X-Center Finding )
G1 Z-[#<rad> + #8] F#<rapid>
    G91
    G38.2 X-#3 F#5
    #<x1> = #5061
G1 X#7 F#<rapid>
    G38.2 X-[#7 * 1.5] F#6
    #<x1> = #5061
    G90
G1 X#<dia> F#<rapid>
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    