( ThorCNC - Outside Bottom Edge )
( #1: Edge Width, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid, #12: XY Cl, #13: Step Off )

O<outside_edge_bottom> sub
    ( 1. Initialization )
    G90 G17 G40 G21

    ( 1. Z-Probe )
    G91
    G38.2 Z-[#4] F#5
    G1 Z#13 F#11 ( Step Off )
    G38.2 Z-[#13 * 2] F#6 ( Fine Probe )
    ( Tool is now physically at probed surface )
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0 ( Zero Z in WCS at surface )
    O101 endif
    G1 Z#7 F#11 ( Relative up to Z clearance above surface )

    G90
    #<start_y> = #5421
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    #<plunge_delta> = [#7 + #<rad> + #8] ( Distance from clearance down to probing depth )

    ( 2. Y-Probe from bottom )
    G1 Y[#<start_y> - #12] F#<rapid>
    G91
    G1 Z-#<plunge_delta> F#<rapid> ( Plunge relative to surface )

    G38.2 Y[#12 + #3] F#5
    G1 Y-[#13] F#<rapid>
    G38.2 Y[#13 * 1.5] F#6
    #<y_hit> = #5062
    G1 Y-[#13] F#<rapid>
    ( Raise Z back to clearance )
    G1 Z#<plunge_delta> F#<rapid>
    G90

    ( 3. Move to Edge & Zero )
    #<y_wall> = [#<y_hit> + #<rad>]
    G1 Y#<y_wall> F#<rapid>
    O102 if [#9 GT 0.5]
        G10 L20 P0 Y0
    O102 endif

O<outside_edge_bottom> endsub
M2
