( ThorCNC - Inside Top Edge )
( #1: Edge Width, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero )

O<inside_edge_top> sub
    ( 1. Z-Probe )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<start_y> = #5421
    #<dia> = #5410
    
    ( 2. Y-Probe to top wall )
    G91
    G38.2 Y#3 F#5
    #<y_hit> = #5062
    G0 Y-[#7]
    G38.2 Y[#7 * 1.5] F#6
    #<y_hit> = #5062
    G90
    G0 Y#<start_y>
    
    ( 3. Final Position & Zeroing )
    O102 if [#9 GT 0.5]
        ( Wall is at y_hit + radius. We want wall to be 0 )
        ( Tool at start_y is at Y = start_y - (y_hit + radius) )
        G10 L20 P0 Y[#<start_y> - [#<y_hit> + [#<dia> / 2]]]
    O102 endif

O<inside_edge_top> endsub
M2
