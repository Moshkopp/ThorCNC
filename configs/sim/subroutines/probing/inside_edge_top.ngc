( ThorCNC - Inside Top Edge )
( #1: Edge Width, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid, #12: XY Cl, #13: Step Off )

O<inside_edge_top> sub
    ( 1. Initialization )
    G90 G17 G40 G21
    G92.1 ( Cancel any lingering G92 offsets )
    M50 P0 ( Disable Feed Override )

    ( 2. Z-Probe to find top )
    G91
    G38.2 Z-[#4] F#5
    G1 Z#13 F#11 ( Step Off )
    G38.2 Z-[#13 * 2] F#6 ( Fine Probe )
    ( Tool is now physically at probed surface )

    G90 ( From here on Z is absolute in current WCS )

    ( 3. Capture surface in current WCS )
    #<z_surface> = #5063
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0 ( Zero Z in WCS at surface )
        #<z_surface> = 0 ( WCS shifted - surface is now at 0 )
    O101 endif

    #<z_clearance> = [#<z_surface> + #7]
    #<z_plunge>    = [#<z_surface> - #8]

    G1 Z#<z_clearance> F#11 ( Absolute raise to clearance )

    ( 4. Common variables )
    #<start_y> = #5421
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    #<jump_y> = -[#12]

    ( 5. Move into Pocket & Plunge )
    G91
    G1 Y#<jump_y> F#<rapid>
    G90
    G1 Z#<z_plunge> F#<rapid> ( Absolute plunge to probing depth )

    ( 6. Y-Probe to top wall )
    G91
    G38.2 Y[#12 + #3] F#5
    G1 Y-[#13] F#<rapid>
    G38.2 Y[#13 * 1.5] F#6
    #<y_hit> = #5062
    G1 Y-[#13] F#<rapid>

    G90
    G1 Z#<z_clearance> F#<rapid> ( Absolute raise to clearance )

    ( 7. Move to Edge & Zero )
    #<y_wall> = [#<y_hit> + #<rad>]
    G1 Y#<y_wall> F#<rapid>
    O102 if [#9 GT 0.5]
        G10 L20 P0 Y0
    O102 endif

    ( 8. Cleanup )
    M50 P1 ( Re-enable Feed Override )

O<inside_edge_top> endsub
M2
