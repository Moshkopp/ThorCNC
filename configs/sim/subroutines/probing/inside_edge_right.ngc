( ThorCNC - Inside Right Edge )
( #1: Edge Width, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid, #12: XY Cl, #13: Step Off )

O<inside_edge_right> sub
    ( 1. Initialization )
    G90 G17 G40 G21
    
    ( 1. Z-Probe to find top )
    G91
    G38.2 Z-[#4] F#5
    G1 Z#13 F#11 ( Step Off )
    G38.2 Z-[#13 * 2] F#6 ( Fine Probe )
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G1 Z#7 F#11
    G90

    #<start_x> = #5420
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    #<rad> = [#<dia> / 2]
    #<jump_x> = -[#12]
    
    ( 2. Move into Pocket & Plunge )
    G91
    G1 X#<jump_x> F#11
    G90
    G1 Z-[#<rad> + #8] F#11
    
    ( 3. X-Probe to right wall )
    G91
    G38.2 X[#12 + #3] F#5
    G1 X-[#13] F#11
    G38.2 X[#13 * 1.5] F#6
    #<x_hit> = #5061
    G1 X-[#13] F#11
    G90
    
    ( 4. Move to Edge & Zero )
    #<x_wall> = [#<x_hit> + #<rad>]
    G1 Z#7 F#11
    G1 X#<x_wall> F#11
    O102 if [#9 GT 0.5]
        G10 L20 P0 X0
    O102 endif

O<inside_edge_right> endsub
M2
