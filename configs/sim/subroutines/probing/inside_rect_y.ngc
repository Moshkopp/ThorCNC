( ThorCNC - Inside Center Finder Y AXIS )
( Args: )
( #2: Y Length )
( #3: Max XY Search Distance )
( #4: Max Z Search Distance )
( #5: Search Velocity )
( #6: Probe Velocity )
( #7: Z Clearance / Retract )
( #8: Probe Depth - Distance below Z0 )
( #9: Auto Zero - 1=ON, 0=OFF )

O<inside_rect_y> sub
    ( Save current state )
    M68 E0 Q0
    
    ( 1. Z-Probe at center )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<start_y> = #5421
    
    ( 2. Y-Center Finding )
    ( Probe Y- side )
    G1 Z-[#8] F[#5 * 2]
    G91
    G38.2 Y-#3 F#5
    #<y1> = #5062
    G0 Y#7
    G38.2 Y-[#7 * 1.5] F#6
    #<y1> = #5062
    G90
    G0 Y#<start_y>

    ( Probe Y+ side )
    G91
    G38.2 Y#3 F#5
    #<y2> = #5062
    G0 Y-#7
    G38.2 Y[#7 * 1.5] F#6
    #<y2> = #5062
    G90
    G0 Y#<start_y>
    
    #<y_center> = [[#<y1> + #<y2>] / 2]

    ( 3. Final Positioning )
    G0 Y#<y_center>
    O102 if [#9 GT 0.5]
        G10 L20 P0 Y0
    O102 endif
    G0 Z#7
    
O<inside_rect_y> endsub
M2
