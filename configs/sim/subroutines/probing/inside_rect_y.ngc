( ThorCNC - Inside Center Finder Y-Axis Rect )
( #2: Y Length, #3: Max XY Search, #4: Max Z Search, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid )

O<inside_rect_y> sub
    ( 1. Z-Probe at center )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<start_y> = #5421
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    
    ( Move to probe depth )
    G1 Z-[#<rad> + #8] F#<rapid>

    ( 2. Y-Center Finding )
    ( Probe Y- side )
    G91
    G38.2 Y-[#3] F#5
    #<y1> = #5062
    G1 Y#7 F#<rapid>
    G38.2 Y-[#7 * 1.5] F#6
    #<y1> = #5062
    G90
    G1 Y#<start_y> F#<rapid>
    
    ( Probe Y+ side )
    G91
    G38.2 Y#3 F#5
    #<y2> = #5062
    G1 Y-#7 F#<rapid>
    G38.2 Y[#7 * 1.5] F#6
    #<y2> = #5062
    G90
    
    #<y_center> = [[#<y1> + #<y2>] / 2]

    ( 3. Final Positioning & Zeroing )
    G1 Y#<y_center> F#<rapid>
    O102 if [#9 GT 0.5]
        G10 L20 P0 Y0
    O102 endif
    G1 Z#7 F#<rapid>

O<inside_rect_y> endsub
M2
