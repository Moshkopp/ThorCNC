( ThorCNC - Inside Bottom-Left Corner )
( #1: Edge Width, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid )

O<inside_corner_bl> sub
    ( 1. Z-Probe to find pocket floor if needed )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<start_x> = #5420
    #<start_y> = #5421
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    
    ( 2. X-Probe to left wall )
    G91
    G38.2 X-[#3] F#5
    #<x_hit> = #5061
    G1 X#7 F#<rapid>
    G38.2 X-[#7 * 1.5] F#6
    #<x_hit> = #5061
    G90
    G1 X#<start_x> F#<rapid>
    
    ( 3. Y-Probe to bottom wall )
    G91
    G38.2 Y-[#3] F#5
    #<y_hit> = #5062
    G1 Y#7 F#<rapid>
    G38.2 Y-[#7 * 1.5] F#6
    #<y_hit> = #5062
    G90
    G1 Y#<start_y> F#<rapid>
    
    ( 4. Final Position & Zeroing )
    G1 X#<start_x> Y#<start_y> F#<rapid>
    O102 if [#9 GT 0.5]
        ( Left wall is at x_hit - radius. Bottom wall is at y_hit - radius )
        G10 L20 P0 X[#5420 - [#<x_hit> - #<rad>]] Y[#5421 - [#<y_hit> - #<rad>]]
    O102 endif
O<inside_corner_bl> endsub
M2
