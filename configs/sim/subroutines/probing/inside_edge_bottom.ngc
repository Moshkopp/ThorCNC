( ThorCNC - Inside Bottom Edge )
( #1: Edge Width, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid, #12: XY Cl, #13: Step Off )

O<inside_edge_bottom> sub
    ( 1. Initialization )
    G90 G17 G40 G21
    
    ( 1. Z-Probe to find top )
    G91
    G38.2 Z-[#4] F#5
    G1 Z#13 F#11 ( Step Off )
    G38.2 Z-[#13 * 2] F#6 ( Fine Probe )
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G1 Z#7 F#11
    G90

    #<start_y> = #5421
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    #<rad> = [#<dia> / 2]
    #<jump_y> = #12
    
    ( 2. Move into Pocket & Plunge )
    G91
    G1 Y#<jump_y> F#11
    G90
    G1 Z-[#8] F#11
    
    ( 3. Y-Probe to bottom wall )
    G91
    G38.2 Y-#3 F#5
    G1 Y#13 F#11
    G38.2 Y[#13 * 1.5] F#6
    #<y_hit> = #5062
    G1 Y#13 F#11
    G90
    
    ( 4. Move to Edge & Zero )
    #<y_wall> = [#<y_hit> - #<rad>]
    G1 Y#<y_wall> F#11
    O102 if [#9 GT 0.5]
        G10 L20 P0 Y0
    O102 endif
    G1 Z#7 F#11

O<inside_edge_bottom> endsub
M2
