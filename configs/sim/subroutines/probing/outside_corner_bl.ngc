( ThorCNC - Outside Bottom-Left Corner )
( #1: Edge Width, #3: Max XY, #4: Max Z, #5: Search Vel, #6: Probe Vel, #7: Z Cl, #8: Depth, #9: Auto Zero, #10: Probe Dia, #11: Probe Rapid, #12: XY Cl, #13: Step Off )

O<outside_corner_bl> sub
    ( 1. Z-Probe )
    G91
    G38.2 Z-[#4] F#5
    G0 Z#7
    G38.2 Z-[#7 * 1.5] F#6
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0
    O101 endif
    G0 Z#7
    G90

    #<start_x> = #5420
    #<start_y> = #5421
    #<dia> = #10
    O<check_dia> if [#<dia> LE 0]
        #<dia> = #5410
    O<check_dia> endif
    #<rapid> = #11
    O<check_rapid> if [#<rapid> LE 0]
        #<rapid> = [#5 * 2]
    O<check_rapid> endif
    #<rad> = [#<dia> / 2]
    
    ( 2. X-Probe from left )
    ( Move Left by EdgeWidth + XY_Clearance )
    G1 X[#<start_x> - #1 - #12] Y#<start_y> F#<rapid>
    ( Plunge to depth )
    G1 Z-[#<rad> + #8] F#<rapid>
    
    ( Search Probe X+ )
    G91
    G38.2 X[#12 + #3] F#5
    #<x_hit> = #5061
    ( Retract by Step Off )
    G1 X-[#13] F#<rapid>
    ( Fine Probe X+ )
    G38.2 X[#13 * 1.5] F#6
    #<x_hit> = #5061
    G90
    ( Raise Z higher for safe travel over the corner )
    G1 Z[#7 * 2] F#<rapid>
    
    ( 3. Y-Probe from bottom )
    ( Move Bottom by EdgeWidth + XY_Clearance )
    G1 X#<start_x> Y[#<start_y> - #1 - #12] F#<rapid>
    ( Plunge to depth )
    G1 Z-[#<rad> + #8] F#<rapid>
    
    ( Search Probe Y+ )
    G91
    G38.2 Y[#12 + #3] F#5
    #<y_hit> = #5062
    ( Retract by Step Off )
    G1 Y-[#13] F#<rapid>
    ( Fine Probe Y+ )
    G38.2 Y[#13 * 1.5] F#6
    #<y_hit> = #5062
    G90
    ( Raise Z higher for safe travel )
    G1 Z[#7 * 2] F#<rapid>
    
    ( 4. Move to Corner & Zero )
    #<x_corner> = [#<x_hit> + #<rad>]
    #<y_corner> = [#<y_hit> + #<rad>]
    
    ( Move to found corner at safe Z )
    G1 X#<x_corner> Y#<y_corner> F#<rapid>
    
    O102 if [#9 GT 0.5]
        ( Current position is now exactly above the corner )
        G10 L20 P0 X0 Y0
    O102 endif
    
    ( Move to clearance height Z )
    G1 Z#7 F#<rapid>

O<outside_corner_bl> endsub
M2
