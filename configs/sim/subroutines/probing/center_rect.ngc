( ThorCNC - Center Finder Rectangular Boss )
( Args: )
( #1: X Length )
( #2: Y Length )
( #3: Max XY Search Distance )
( #4: Max Z Search Distance )
( #5: Search Velocity )
( #6: Probe Velocity )
( #7: Z Clearance / Retract )
( #8: Probe Depth - Distance below Z0 )
( #9: Auto Zero - 1=ON, 0=OFF )

O<center_rect> sub
    ( Save current state )
    M68 E0 Q0 ( Placeholder for any needed HAL sync )
    
    ( 1. Z-Probe )
    G91 ( Incremental mode )
    G38.2 Z-[#4] F#5 ( Search Z- )
    G0 Z#7 ( Retract )
    G38.2 Z-[#7 * 1.5] F#6 ( Fine probe )
    O101 if [#9 GT 0.5]
        G10 L20 P0 Z0 ( Set Z Work Offset to 0 )
    O101 endif
    G0 Z#7 ( Safe retract )
    G90 ( Absolute mode )

    ( 2. X-Center Finding )
    #<search_dist> = [[#1 / 2] + #3]
    
    ( Probe X- side )
    G0 X-[#<search_dist>] Y0
    G1 Z-[#8] F[#5 * 2] ( Move down to probe depth )
    G91
    G38.2 X#3 F#5 ( Search X+ )
    #<x1> = #5061 ( #5061 is X position of last probe hit )
    G0 X-[#7] ( Back off )
    G38.2 X[#7 * 1.5] F#6 ( Fine probe X+ )
    #<x1> = #5061
    G90
    G0 Z#7 ( Retract to safe Z )

    ( Probe X+ side )
    G0 X[#<search_dist>] Y0
    G1 Z-[#8] F[#5 * 2]
    G91
    G38.2 X-#3 F#5 ( Search X- )
    #<x2> = #5061
    G0 X#7 ( Back off )
    G38.2 X-[#7 * 1.5] F#6 ( Fine probe X- )
    #<x2> = #5061
    G90
    G0 Z#7 ( Retract )
    
    #<x_center> = [[#<x1> + #<x2>] / 2]

    ( 3. Y-Center Finding )
    #<search_dist_y> = [[#2 / 2] + #3]
    
    ( Probe Y- side )
    G0 X#<x_center> Y-[#<search_dist_y>]
    G1 Z-[#8] F[#5 * 2]
    G91
    G38.2 Y#3 F#5 ( Search Y+ )
    #<y1> = #5062 ( #5062 is Y position )
    G0 Y-[#7]
    G38.2 Y[#7 * 1.5] F#6
    #<y1> = #5062
    G90
    G0 Z#7

    ( Probe Y+ side )
    G0 X#<x_center> Y[#<search_dist_y>]
    G1 Z-[#8] F[#5 * 2]
    G91
    G38.2 Y-#3 F#5 ( Search Y- )
    #<y2> = #5062
    G0 Y#7
    G38.2 Y-[#7 * 1.5] F#6
    #<y2> = #5062
    G90
    G0 Z#7
    
    #<y_center> = [[#<y1> + #<y2>] / 2]

    ( 4. Final Positioning )
    G0 X#<x_center> Y#<y_center>
    O102 if [#9 GT 0.5]
        G10 L20 P0 X0 Y0 ( Zero work offsets for X and Y )
    O102 endif
    
    ( Return to safe height )
    G0 Z#7
    
O<center_rect> endsub
M2
