# ThorCNC PostGUI HAL (Simulation Test Configuration)

# Simulation: Automatischen Werkzeugwechsel unterbrechen für ThorCNC-Test
unlinkp iocontrol.0.tool-change
unlinkp iocontrol.0.tool-changed

# Neu verdrahten mit ThorCNC Dialog
net tool-change-request    iocontrol.0.tool-change           thorcnc.tool-change-request
net tool-change-confirmed  thorcnc.tool-changed-confirm      iocontrol.0.tool-changed
net tool-number            iocontrol.0.tool-prep-number      thorcnc.tool-number
